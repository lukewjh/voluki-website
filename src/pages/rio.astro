      margin: 0;
      padding-left: 18px;
    }

    .rio-next-button,
    .rio-ghost-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      border-radius: 8px;
      padding: 0 18px;
      font: inherit;
      font-size: 14px;
      font-weight: 850;
      cursor: pointer;
      transition:
        opacity 160ms ease,
        transform 160ms ease;
    }

    .rio-next-button {
      border: 0;
      background: var(--text);
      color: var(--bg);
    }

    .rio-ghost-button {
      border: 1px solid var(--line);
      background: var(--surface);
      color: var(--text);
    }

    .rio-next-button:hover,
    .rio-next-button:focus-visible,
    .rio-ghost-button:hover,
    .rio-ghost-button:focus-visible {
      opacity: 0.86;
      outline: none;
      transform: translateY(-1px);
    }

    @media (max-width: 900px) {
      .rio-table-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .rio-modal.is-opening .rio-modal-backdrop,
      .rio-modal.is-closing .rio-modal-backdrop,
      .rio-modal.is-opening .rio-modal-card,
      .rio-modal.is-closing .rio-modal-card,
      .rio-modal-card.is-celebrating::after,
      :global(.rio-confetti-piece) {
        animation: none;
      }
    }
  </style>

  <script>
    const modal = document.querySelector("[data-rio-modal]");
    const modalCard = document.querySelector(".rio-modal-card");
    const openButton = document.querySelector("[data-rio-modal-open]");
    const closeButtons = document.querySelectorAll("[data-rio-modal-close]");
    const addButtons = document.querySelectorAll("[data-rio-add-item]");
    const quizMaterialButtons = document.querySelectorAll("[data-rio-quiz-material]");
    const quizModal = document.querySelector("[data-rio-quiz-modal]");
    const quizCloseButtons = document.querySelectorAll("[data-rio-quiz-close]");
    const quizStage = document.querySelector("[data-rio-quiz-stage]");
    const quizMaterialBadge = document.querySelector("[data-rio-quiz-material-badge]");
    const progressLabels = document.querySelectorAll("[data-rio-selection-progress]");
    const badgesBox = document.querySelector("[data-rio-material-badges]");
    const passageBox = document.querySelector("[data-rio-generated-passage]");
    const challengeList = document.querySelector("[data-rio-challenge-list]");
    const inputError = document.querySelector("[data-rio-input-error]");
    const celebrationLayer = document.querySelector("[data-rio-celebration]");
    const pageButtons = {
      next: document.querySelector("[data-rio-next]"),
      prev: document.querySelector("[data-rio-prev]"),
      grammarCheck: document.querySelector("[data-rio-grammar-check]"),
      backToAnswer: document.querySelector("[data-rio-back-to-answer]"),
      complete: document.querySelector("[data-rio-complete]")
    };
    const pages = document.querySelectorAll("[data-rio-page]");
    const modalTitle = document.querySelector("#rio-modal-title");
    const analysisList = document.querySelector("[data-rio-analysis-list]");
    let lastFocusedElement;
    let activeReader;
    let activeController;
    let generationId = 0;
    let celebrationTimer;
    let modalAnimationTimer;
    let isClosingModal = false;
    const completeButtonLabel = pageButtons.complete?.textContent ?? "";
    const selectionRequirements = {
      chunk: 3,
      sentence_pattern: 1,
      vocabulary: 2,
      adverb: 1
    };
    const selectedTargets = {
      chunk: [],
      sentence_pattern: [],
      vocabulary: [],
      adverb: []
    };
    const modalState = {
      page: 1,
      materials: null,
      trainingPackage: null,
      englishPassage: "",
      challenges: [],
      userAnswers: [],
      analysis: null,
      isCheckingGrammar: false
    };
    const quizState = {
      material: null,
      cards: [],
      answers: [],
      currentIndex: 0,
      isLoading: false,
      generationId: 0,
      loadingMessageIndex: 0,
      loadingCycleTimer: undefined,
      loadingTypeTimer: undefined,
      lastFocusedElement: null
    };
    const quizLoadingMessages = [
      "正在生成 Quiz 卡片...",
      "题目正在路上...",
      "AI正在快速生成，请稍后..."
    ];

    const getSelectedCount = () =>
      Object.values(selectedTargets).reduce((total, items) => total + items.length, 0);

    const getSelectedPayload = () =>
      Object.fromEntries(
        Object.entries(selectedTargets).map(([type, items]) => [
          type,
          items.map((item) => item.id)
        ])
      );

    const updateSelectionUi = () => {
      progressLabels.forEach((label) => {
        if (!(label instanceof HTMLElement)) return;

        const type = label.getAttribute("data-rio-selection-progress");
        const selected = selectedTargets[type]?.length ?? 0;
        const required = selectionRequirements[type] ?? 0;
        label.textContent = `${selected}/${required}`;
      });

      addButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;

        const type = button.getAttribute("data-rio-item-type");
        const id = Number(button.getAttribute("data-rio-item-id"));
        const selectedItems = selectedTargets[type] ?? [];
        const isSelected = selectedItems.some((item) => item.id === id);
        const isFull = selectedItems.length >= (selectionRequirements[type] ?? 0);

        button.classList.toggle("is-selected", isSelected);
        button.textContent = isSelected ? "✓" : "+";
        button.disabled = !isSelected && isFull;
        button.setAttribute("aria-pressed", String(isSelected));
      });

      if (openButton instanceof HTMLButtonElement) {
        openButton.textContent = getSelectedCount() ? "开始练习" : "随机生成";
      }
    };

    const updateGrammarButtonLabel = () => {
      if (pageButtons.grammarCheck instanceof HTMLElement) {
        pageButtons.grammarCheck.textContent = modalState.analysis ? "再次语法检查" : "语法检查";
      }
    };

    const resetModalSession = () => {
      modalState.page = 1;
      modalState.materials = null;
      modalState.trainingPackage = null;
      modalState.englishPassage = "";
      modalState.challenges = [];
      modalState.userAnswers = [];
      modalState.analysis = null;
      modalState.isCheckingGrammar = false;
      updateGrammarButtonLabel();
    };

    const finishCloseModal = () => {
      if (!(modal instanceof HTMLElement)) return;

      resetModalSession();
      if (pageButtons.complete instanceof HTMLButtonElement) {
        pageButtons.complete.disabled = false;
        pageButtons.complete.textContent = completeButtonLabel;
      }
      modalCard?.classList.remove("is-celebrating");
      if (celebrationLayer instanceof HTMLElement) {
        celebrationLayer.hidden = true;
        celebrationLayer.replaceChildren();
      }
      modal.classList.remove("is-opening", "is-closing");
      modal.hidden = true;
      isClosingModal = false;
      document.body.style.overflow = "";

      if (lastFocusedElement instanceof HTMLElement) {
        lastFocusedElement.focus();
      }
    };

    const closeModal = () => {
      if (!(modal instanceof HTMLElement) || modal.hidden || isClosingModal) return;

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      isClosingModal = true;
      window.clearTimeout(celebrationTimer);
      window.clearTimeout(modalAnimationTimer);
      generationId += 1;
      activeController?.abort?.();
      activeReader?.cancel?.();
      activeReader = undefined;
      activeController = undefined;
      passageBox?.classList.remove("is-loading");
      openButton?.removeAttribute("disabled");
      modalCard?.classList.remove("is-celebrating");

      if (celebrationLayer instanceof HTMLElement) {
        celebrationLayer.hidden = true;
        celebrationLayer.replaceChildren();
      }

      if (reduceMotion) {
        finishCloseModal();
        return;
      }

      modal.classList.remove("is-opening");
      modal.classList.add("is-closing");
      modalAnimationTimer = window.setTimeout(finishCloseModal, 190);
    };

    const launchCompletionCelebration = () => {
      if (!(modal instanceof HTMLElement) || modal.hidden) return;

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (reduceMotion) {
        closeModal();
        return;
      }

      if (pageButtons.complete instanceof HTMLButtonElement) {
        pageButtons.complete.disabled = true;
        pageButtons.complete.textContent = "\u5b8c\u6210\u5566";
      }

      modalCard?.classList.add("is-celebrating");

      if (celebrationLayer instanceof HTMLElement) {
        const colors = ["#e5484d", "#f59e0b", "#22c55e", "#3b82f6", "#a855f7", "#14b8a6"];
        const pieceCount = window.innerWidth < 680 ? 42 : 72;
        const cardRect = modalCard instanceof HTMLElement ? modalCard.getBoundingClientRect() : null;
        const originX = cardRect ? cardRect.left + cardRect.width / 2 : window.innerWidth / 2;
        const originY = cardRect ? cardRect.top + 24 : Math.max(86, window.innerHeight * 0.24);

        celebrationLayer.replaceChildren();
        celebrationLayer.hidden = false;

        for (let index = 0; index < pieceCount; index += 1) {
          const piece = document.createElement("span");
          const spread = index / pieceCount;
          const direction = spread * Math.PI * 2;
          const distance = 110 + Math.random() * (window.innerWidth < 680 ? 170 : 260);
          const drift = (Math.random() - 0.5) * 160;

          piece.className = "rio-confetti-piece";
          piece.style.setProperty("--confetti-color", colors[index % colors.length]);
          piece.style.setProperty("--confetti-width", `${6 + Math.random() * 6}px`);
          piece.style.setProperty("--confetti-height", `${9 + Math.random() * 10}px`);
          piece.style.setProperty("--confetti-origin-x", `${originX}px`);
          piece.style.setProperty("--confetti-origin-y", `${originY}px`);
          piece.style.setProperty("--confetti-x", `${Math.cos(direction) * distance + drift}px`);
          piece.style.setProperty("--confetti-y", `${Math.sin(direction) * 95 + 180 + Math.random() * 130}px`);
          piece.style.setProperty("--confetti-spin", `${Math.random() * 180}deg`);
          piece.style.setProperty("--confetti-rotation", `${360 + Math.random() * 720}deg`);
          piece.style.setProperty("--confetti-scale", String(0.72 + Math.random() * 0.58));
          piece.style.setProperty("--confetti-delay", `${Math.random() * 110}ms`);
          piece.style.setProperty("--confetti-duration", `${850 + Math.random() * 420}ms`);
          celebrationLayer.append(piece);
        }
      }

      window.clearTimeout(celebrationTimer);
      celebrationTimer = window.setTimeout(closeModal, 1250);
    };

    const openModal = () => {
      if (!(modal instanceof HTMLElement)) return;

      window.clearTimeout(modalAnimationTimer);
      isClosingModal = false;
      lastFocusedElement = document.activeElement;
      modal.classList.remove("is-closing");
      modal.hidden = false;
      modal.classList.add("is-opening");
      document.body.style.overflow = "hidden";
      modalAnimationTimer = window.setTimeout(() => {
        modal.classList.remove("is-opening");
      }, 230);
      modal.querySelector("button")?.focus();
      if (challengeList instanceof HTMLElement) {
        challengeList.innerHTML =
          '<p class="rio-analysis-placeholder">中文翻译小题会在这里显示。</p>';
      }
      if (inputError instanceof HTMLElement) {
        inputError.hidden = true;
      }
      if (analysisList instanceof HTMLElement) {
        analysisList.innerHTML = '<p class="rio-analysis-placeholder">语法检查结果会在这里显示。</p>';
      }
      updateGrammarButtonLabel();
      showPage(1);
      generatePassage();
    };

    const escapeHtml = (value) =>
      String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;");

    const getQuizMaterials = (type) =>
      Array.from(quizMaterialButtons)
        .filter((button) => button instanceof HTMLElement)
        .map((button) => ({
          id: Number(button.getAttribute("data-rio-material-id")),
          type: button.getAttribute("data-rio-material-type") ?? "",
          text: button.getAttribute("data-rio-material-text") ?? "",
          button
        }))
        .filter((item) => Number.isFinite(item.id) && item.type && item.text)
        .filter((item) => !type || item.type === type);

    const getQuizInstruction = (material) =>
      material?.type === "chunk"
        ? "选出最地道的英文搭配。"
        : material?.type === "vocabulary"
          ? "选出当前语境下最合适的同义替换。"
        : material?.type === "adverb"
          ? "根据上下文选择最合适的副词。"
          : "选出最准确的中文翻译。";

    const getQuizCompleteCopy = (material) =>
      material?.type === "chunk"
        ? "换一个 chunk 继续刷题，把固定搭配练成更快的语言反应。"
        : material?.type === "vocabulary"
          ? "换一个单词继续刷题，把高级词快速降维成核心意思。"
        : material?.type === "adverb"
          ? "换一个副词继续刷题，把语气和逻辑判断练快。"
          : "换一个句型继续刷题，把结构识别变成更快的阅读反应。";

    const getQuizNextLabel = (material) =>
      material?.type === "chunk"
        ? "下一个 chunk"
        : material?.type === "vocabulary"
          ? "下一个单词"
        : material?.type === "adverb"
          ? "下一个副词"
          : "下一个句型";

    const getQuizExpectedCount = (material) => (material?.type === "chunk" ? 5 : 3);

    const normalizeBuilderChunk = (value) =>
      String(value ?? "")
        .trim()
        .toLocaleLowerCase()
        .replace(/\s+/g, " ");

    const renderQuizSentence = (card) => {
      const sentence = String(card?.english_sentence ?? "");
      const targetText = String(card?.target_text ?? "").trim();
      if (!targetText) return escapeHtml(sentence);

      const matchIndex = sentence.toLocaleLowerCase().indexOf(targetText.toLocaleLowerCase());
      if (matchIndex < 0) return escapeHtml(sentence);

      const before = sentence.slice(0, matchIndex);
      const matched = sentence.slice(matchIndex, matchIndex + targetText.length);
      const after = sentence.slice(matchIndex + targetText.length);

      return `${escapeHtml(before)}<mark class="rio-quiz-target-word">${escapeHtml(
        matched
      )}</mark>${escapeHtml(after)}`;
    };

    const renderBuilderAnswer = (answerBox, selectedChunks) => {
      if (!(answerBox instanceof HTMLElement)) return;
      answerBox.innerHTML = selectedChunks.length
        ? selectedChunks
            .map(
              (item, index) =>
                `<button class="rio-quiz-builder-chip" type="button" data-rio-builder-remove="${index}">${escapeHtml(
                  item.text
                )}</button>`
            )
            .join("")
        : '<span class="rio-analysis-placeholder">点击上方词块排序</span>';
    };

    const isQuizCardAnswered = (index) => typeof quizState.answers[index]?.isCorrect === "boolean";

    const areAllQuizCardsAnswered = () =>
      quizState.cards.length > 0 &&
      quizState.cards.every((_, index) => isQuizCardAnswered(index));

    const renderQuizNav = () => {
      const expectedCount = getQuizExpectedCount(quizState.material);
      const isLast = quizState.currentIndex >= expectedCount - 1;
      const canFinish = areAllQuizCardsAnswered();

      return `<div class="rio-quiz-nav">
        <button class="rio-quiz-nav-button" type="button" data-rio-quiz-prev-card ${
          quizState.currentIndex <= 0 ? "disabled" : ""
        }>上一题</button>
        <button class="rio-quiz-nav-button primary" type="button" data-rio-quiz-next-card ${
          isLast && !canFinish ? "disabled" : ""
        }>${isLast ? "完成" : "下一题"}</button>
      </div>`;
    };

    const bindQuizNav = () => {
      quizStage?.querySelector("[data-rio-quiz-prev-card]")?.addEventListener("click", () => {
        if (quizState.currentIndex <= 0) return;
        quizState.currentIndex -= 1;
        renderQuizCard();
      });

      quizStage?.querySelector("[data-rio-quiz-next-card]")?.addEventListener("click", () => {
        const expectedCount = getQuizExpectedCount(quizState.material);
        const isLast = quizState.currentIndex >= expectedCount - 1;

        if (isLast) {
          if (areAllQuizCardsAnswered()) renderQuizComplete();
          return;
        }

        quizState.currentIndex += 1;
        renderQuizCard();
      });
    };

    const shuffleQuizOptions = (options, correctLabel) => {
      const labels = ["A", "B", "C", "D"];
      const shuffled = [...options];

      for (let index = shuffled.length - 1; index > 0; index -= 1) {
        const target = Math.floor(Math.random() * (index + 1));
        [shuffled[index], shuffled[target]] = [shuffled[target], shuffled[index]];
      }

      return shuffled.map((option, index) => ({
        ...option,
        displayLabel: labels[index] ?? option.label,
        isCorrect: option.label === correctLabel
      }));
    };

    const stopQuizLoadingMessages = () => {
      window.clearTimeout(quizState.loadingCycleTimer);
      window.clearTimeout(quizState.loadingTypeTimer);
      quizState.loadingCycleTimer = undefined;
      quizState.loadingTypeTimer = undefined;
    };

    const typeQuizLoadingMessage = (element, message, charIndex = 0) => {
      if (!(element instanceof HTMLElement) || !quizState.isLoading) return;

      element.textContent = message.slice(0, charIndex);

      if (charIndex < message.length) {
        quizState.loadingTypeTimer = window.setTimeout(() => {
          typeQuizLoadingMessage(element, message, charIndex + 1);
        }, 42);
      }
    };

    const scheduleQuizLoadingMessage = () => {
      if (!quizState.isLoading) return;

      const element = quizStage?.querySelector("[data-rio-quiz-loading-text]");
      if (!(element instanceof HTMLElement)) return;

      window.clearTimeout(quizState.loadingTypeTimer);
      const message =
        quizLoadingMessages[quizState.loadingMessageIndex % quizLoadingMessages.length];
      typeQuizLoadingMessage(element, message);
      quizState.loadingMessageIndex += 1;
      quizState.loadingCycleTimer = window.setTimeout(scheduleQuizLoadingMessage, 1600);
    };

    const renderQuizLoading = () => {
      if (!(quizStage instanceof HTMLElement)) return;

      stopQuizLoadingMessages();
      quizState.loadingMessageIndex = 0;
      quizStage.innerHTML =
        '<p class="rio-analysis-placeholder rio-quiz-loading-panel"><span class="rio-quiz-loading-text" data-rio-quiz-loading-text></span></p>';
      scheduleQuizLoadingMessage();
    };

    const renderQuizError = (message) => {
      if (!(quizStage instanceof HTMLElement)) return;

      stopQuizLoadingMessages();
      quizStage.innerHTML = `<div class="rio-quiz-complete">
        <p class="rio-analysis-placeholder">${escapeHtml(message)}</p>
        <div class="rio-quiz-retry-actions">
          <button class="rio-quiz-retry-button" type="button" data-rio-quiz-retry>重新生成</button>
        </div>
      </div>`;
      quizStage.querySelector("[data-rio-quiz-retry]")?.addEventListener("click", () => {
        if (quizState.material) {
          generateQuiz(quizState.material);
        }
      });
    };

    const closeQuizModal = () => {
      if (!(quizModal instanceof HTMLElement)) return;

      stopQuizLoadingMessages();
      quizModal.classList.remove("is-opening");
      quizModal.hidden = true;
      quizState.material = null;
      quizState.cards = [];
      quizState.answers = [];
      quizState.currentIndex = 0;
      quizState.isLoading = false;
      quizState.generationId += 1;
      document.body.style.overflow = "";

      if (quizState.lastFocusedElement instanceof HTMLElement) {
        quizState.lastFocusedElement.focus();
      }
    };

    const renderQuizMaterialBadge = (material) => {
      if (!(quizMaterialBadge instanceof HTMLElement)) return;

      const type =
        material.type === "chunk"
          ? "chunk"
          : material.type === "vocabulary"
            ? "vocabulary"
          : material.type === "adverb"
            ? "adverb"
            : "sentence_pattern";
      quizMaterialBadge.innerHTML = `<span class="rio-material-badge ${type}">${escapeHtml(
        material.text
      )}</span>`;
    };

    const openQuizModal = (material) => {
      if (!(quizModal instanceof HTMLElement)) return;

      closeModal();
      quizState.material = material;
      quizState.lastFocusedElement = document.activeElement;
      quizModal.hidden = false;
      quizModal.classList.add("is-opening");
      document.body.style.overflow = "hidden";
      window.setTimeout(() => {
        quizModal.classList.remove("is-opening");
      }, 230);

      renderQuizMaterialBadge(material);

      renderQuizLoading();
      quizModal.querySelector("button")?.focus();
      generateQuiz(material);
    };

    const getNextQuizMaterial = () => {
      if (!quizState.material) return null;

      const materials = getQuizMaterials(quizState.material.type);
      const currentIndex = materials.findIndex((item) => item.id === quizState.material.id);
      if (!materials.length || currentIndex < 0) return null;

      return materials[(currentIndex + 1) % materials.length];
    };

    const startNextQuizMaterial = () => {
      const nextMaterial = getNextQuizMaterial();
      if (!nextMaterial) return;

      quizState.material = nextMaterial;
      renderQuizMaterialBadge(nextMaterial);
      renderQuizLoading();
      generateQuiz(nextMaterial);
    };

    const launchQuizCompleteConfetti = () => {
      const completeBox = quizStage?.querySelector(".rio-quiz-complete");
      if (!(completeBox instanceof HTMLElement)) return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

      const colors = ["#e5484d", "#f59e0b", "#22c55e", "#3b82f6", "#a855f7", "#14b8a6"];
      const pieceCount = window.innerWidth < 680 ? 26 : 38;

      for (let index = 0; index < pieceCount; index += 1) {
        const piece = document.createElement("span");
        const direction = (index / pieceCount) * Math.PI * 2;
        const distance = 70 + Math.random() * 120;
        const drift = (Math.random() - 0.5) * 70;

        piece.className = "rio-confetti-piece";
        piece.style.setProperty("--confetti-color", colors[index % colors.length]);
        piece.style.setProperty("--confetti-width", `${5 + Math.random() * 5}px`);
        piece.style.setProperty("--confetti-height", `${8 + Math.random() * 8}px`);
        piece.style.setProperty("--confetti-origin-x", "50%");
        piece.style.setProperty("--confetti-origin-y", "74px");
        piece.style.setProperty("--confetti-x", `${Math.cos(direction) * distance + drift}px`);
        piece.style.setProperty("--confetti-y", `${Math.sin(direction) * 58 + 96 + Math.random() * 64}px`);
        piece.style.setProperty("--confetti-spin", `${Math.random() * 180}deg`);
        piece.style.setProperty("--confetti-rotation", `${300 + Math.random() * 620}deg`);
        piece.style.setProperty("--confetti-scale", String(0.66 + Math.random() * 0.48));
        piece.style.setProperty("--confetti-delay", `${Math.random() * 80}ms`);
        piece.style.setProperty("--confetti-duration", `${780 + Math.random() * 360}ms`);
        completeBox.append(piece);
      }

      window.setTimeout(() => {
        completeBox.querySelectorAll(".rio-confetti-piece").forEach((piece) => piece.remove());
      }, 1400);
    };

    const renderQuizComplete = () => {
      if (!(quizStage instanceof HTMLElement)) return;

      stopQuizLoadingMessages();
      const nextMaterial = getNextQuizMaterial();
      const expectedCount = getQuizExpectedCount(quizState.material);
      quizStage.innerHTML = `<div class="rio-quiz-complete">
        <span class="rio-quiz-progress">${expectedCount}/${expectedCount}</span>
        <span class="rio-quiz-complete-mark">✓</span>
        <h3 class="rio-quiz-complete-title">这一轮完成了</h3>
        <p class="rio-quiz-complete-copy">${escapeHtml(getQuizCompleteCopy(quizState.material))}</p>
        <div class="rio-quiz-complete-actions">
          <button class="rio-quiz-complete-button secondary" type="button" data-rio-quiz-close-action>关闭</button>
          ${
            nextMaterial
              ? `<button class="rio-quiz-complete-button primary" type="button" data-rio-quiz-next-material>${escapeHtml(
                  getQuizNextLabel(quizState.material)
                )}</button>`
              : ""
          }
        </div>
      </div>`;

      quizStage
        .querySelector("[data-rio-quiz-close-action]")
        ?.addEventListener("click", closeQuizModal);
      quizStage
        .querySelector("[data-rio-quiz-next-material]")
        ?.addEventListener("click", startNextQuizMaterial);
      launchQuizCompleteConfetti();
    };

    const renderQuizCard = () => {
      if (!(quizStage instanceof HTMLElement)) return;

      stopQuizLoadingMessages();
      const card = quizState.cards[quizState.currentIndex];
      if (!card) {
        renderQuizComplete();
        return;
      }

      const expectedCount = getQuizExpectedCount(quizState.material);
      const sceneLabel = [card.question_type, card.scene].filter(Boolean).join(" · ");

      if (card.question_type === "Sentence Builder") {
        const chunks = Array.isArray(card.chunks) ? card.chunks : [];
        const answerChunks = Array.isArray(card.answer_chunks) ? card.answer_chunks : [];
        const answerState = quizState.answers[quizState.currentIndex] ?? {};
        const selectedChunks = Array.isArray(answerState.builderSelected)
          ? answerState.builderSelected
              .map((index) => ({ index, text: chunks[index] }))
              .filter((item) => typeof item.text === "string")
          : [];
        quizStage.innerHTML = `<article class="rio-quiz-question">
          <span class="rio-quiz-progress">${quizState.currentIndex + 1}/${expectedCount}</span>
          <p class="rio-quiz-scene">${escapeHtml(sceneLabel)}</p>
          <p class="rio-quiz-sentence">${escapeHtml(card.english_sentence ?? "")}</p>
          <div class="rio-quiz-builder">
            <div class="rio-quiz-builder-pool">
              ${chunks
                .map(
                  (chunk, index) =>
                    `<button class="rio-quiz-builder-chip" type="button" data-rio-builder-pick="${index}">${escapeHtml(
                      chunk
                    )}</button>`
                )
                .join("")}
            </div>
            <div class="rio-quiz-builder-answer" data-rio-builder-answer>
              <span class="rio-analysis-placeholder">点击上方词块排序</span>
            </div>
            <div class="rio-quiz-builder-actions">
              <button class="rio-quiz-builder-action" type="button" data-rio-builder-reset>重排</button>
              <button class="rio-quiz-builder-action primary" type="button" data-rio-builder-check>检查</button>
            </div>
          </div>
          <p class="rio-quiz-feedback" data-rio-quiz-feedback>${escapeHtml(
            answerState.feedbackText ?? "按自然英文语序拼出完整句子。"
          )}</p>
          ${renderQuizNav()}
        </article>`;

        const answerBox = quizStage.querySelector("[data-rio-builder-answer]");
        const feedback = quizStage.querySelector("[data-rio-quiz-feedback]");
        const renderBuilder = () => {
          renderBuilderAnswer(answerBox, selectedChunks);
          quizStage.querySelectorAll("[data-rio-builder-pick]").forEach((button) => {
            if (button instanceof HTMLButtonElement) {
              const index = Number(button.getAttribute("data-rio-builder-pick"));
              button.disabled = selectedChunks.some((item) => item.index === index);
              if (answerState.isCorrect) button.disabled = true;
            }
          });
          answerBox?.querySelectorAll("[data-rio-builder-remove]").forEach((button) => {
            button.addEventListener("click", () => {
              const index = Number(button.getAttribute("data-rio-builder-remove"));
              if (!Number.isFinite(index)) return;
              selectedChunks.splice(index, 1);
              renderBuilder();
            });
          });
        };

        quizStage.querySelectorAll("[data-rio-builder-pick]").forEach((button) => {
          button.addEventListener("click", () => {
            if (!(button instanceof HTMLButtonElement)) return;
            const index = Number(button.getAttribute("data-rio-builder-pick"));
          const text = chunks[index];
            if (answerState.isCorrect) return;
            if (!Number.isFinite(index) || typeof text !== "string") return;
            selectedChunks.push({ index, text });
            quizState.answers[quizState.currentIndex] = {
              ...quizState.answers[quizState.currentIndex],
              builderSelected: selectedChunks.map((item) => item.index),
              isCorrect: false
            };
            renderBuilder();
          });
        });

        quizStage.querySelector("[data-rio-builder-reset]")?.addEventListener("click", () => {
          if (answerState.isCorrect) return;
          selectedChunks.splice(0, selectedChunks.length);
          quizState.answers[quizState.currentIndex] = {
            ...quizState.answers[quizState.currentIndex],
            builderSelected: [],
            isCorrect: false,
            feedbackText: "按自然英文语序拼出完整句子。"
          };
          if (feedback instanceof HTMLElement) {
            feedback.textContent = "按自然英文语序拼出完整句子。";
          }
          renderBuilder();
        });

        quizStage.querySelector("[data-rio-builder-check]")?.addEventListener("click", () => {
          const selected = selectedChunks.map((item) => normalizeBuilderChunk(item.text));
          const expected = answerChunks.map(normalizeBuilderChunk);
          const isCorrect =
            selected.length === expected.length &&
            selected.every((item, index) => item === expected[index]);

          if (feedback instanceof HTMLElement) {
            feedback.textContent = isCorrect
              ? card.feedback ?? "对，句子顺序自然。"
              : card.hint ?? "再看主语、谓语、宾语和目的状语的顺序。";
          }

          quizState.answers[quizState.currentIndex] = {
            ...quizState.answers[quizState.currentIndex],
            builderSelected: selectedChunks.map((item) => item.index),
            isCorrect,
            feedbackText: isCorrect
              ? card.feedback ?? "对，句子顺序自然。"
              : card.hint ?? "再看主语、谓语、宾语和目的状语的顺序。"
          };

          if (!isCorrect) return;

          quizStage
            .querySelectorAll("[data-rio-builder-pick], [data-rio-builder-remove], [data-rio-builder-check], [data-rio-builder-reset]")
            .forEach((button) => {
              if (button instanceof HTMLButtonElement) button.disabled = true;
            });
          renderQuizCard();
        });

        renderBuilder();
        if (answerState.isCorrect) {
          quizStage
            .querySelectorAll("[data-rio-builder-pick], [data-rio-builder-remove], [data-rio-builder-check], [data-rio-builder-reset]")
            .forEach((button) => {
              if (button instanceof HTMLButtonElement) button.disabled = true;
            });
        }
        bindQuizNav();
        return;
      }

      if (!Array.isArray(card.displayOptions)) {
        card.displayOptions = shuffleQuizOptions(
          Array.isArray(card.options) ? card.options : [],
          card.correct_label
        );
      }
      const options = card.displayOptions;
      const answerState = quizState.answers[quizState.currentIndex] ?? {};
      quizStage.innerHTML = `<article class="rio-quiz-question">
        <span class="rio-quiz-progress">${quizState.currentIndex + 1}/${expectedCount}</span>
        <p class="rio-quiz-scene">${escapeHtml(sceneLabel)}</p>
        <p class="rio-quiz-sentence">${renderQuizSentence(card)}</p>
        <div class="rio-quiz-options">
          ${options
            .map(
              (option) => {
                const isSelected = answerState.selectedLabel === option.label;
                const shouldShowCorrect = answerState.isCorrect && option.isCorrect;
                const shouldShowWrong = isSelected && answerState.isCorrect === false;

                return `<button
                class="rio-quiz-option${shouldShowCorrect ? " is-correct" : ""}${shouldShowWrong ? " is-wrong" : ""}"
                type="button"
                data-rio-quiz-label="${escapeHtml(option.label ?? "")}"
                data-rio-quiz-correct="${option.isCorrect ? "true" : "false"}"
                ${answerState.isCorrect ? "disabled" : ""}
              >
                <span class="rio-quiz-option-letter">${escapeHtml(option.displayLabel ?? "")}</span>
                <span>${escapeHtml(option.text ?? "")}</span>
              </button>`;
              }
            )
            .join("")}
        </div>
        <p class="rio-quiz-feedback" data-rio-quiz-feedback>${escapeHtml(
          answerState.feedbackText ?? getQuizInstruction(quizState.material)
        )}</p>
        ${renderQuizNav()}
      </article>`;

      quizStage.querySelectorAll("[data-rio-quiz-correct]").forEach((button) => {
        button.addEventListener("click", () => {
          if (!(button instanceof HTMLButtonElement)) return;

          const feedback = quizStage.querySelector("[data-rio-quiz-feedback]");
          const isCorrect = button.getAttribute("data-rio-quiz-correct") === "true";
          const selectedLabel = button.getAttribute("data-rio-quiz-label") ?? "";

          if (isCorrect) {
            button.classList.add("is-correct");
            const feedbackText =
              card.feedback ??
              (quizState.material?.type === "chunk"
                ? "对，这个搭配更自然。"
                : quizState.material?.type === "vocabulary"
                  ? "对，这个词能无缝替换原词。"
                  : quizState.material?.type === "adverb"
                    ? "对，这个副词符合上下文语气。"
                    : "对，结构和意思匹配。");
            if (feedback instanceof HTMLElement) {
              feedback.textContent = feedbackText;
            }
            quizState.answers[quizState.currentIndex] = {
              selectedLabel,
              isCorrect: true,
              feedbackText
            };
            quizStage.querySelectorAll("[data-rio-quiz-correct]").forEach((optionButton) => {
              if (optionButton instanceof HTMLButtonElement) {
                optionButton.disabled = true;
              }
            });
            renderQuizCard();
            return;
          }

          button.classList.add("is-wrong");
          const feedbackText =
            card.hint ??
            (quizState.material?.type === "chunk"
              ? "再看一眼这个语块的固定搭配。"
              : quizState.material?.type === "vocabulary"
                ? "别只看词形，回到句子语境。"
                : quizState.material?.type === "adverb"
                  ? "再看副词位置、强度或适用场景。"
                  : "再看一眼句型的逻辑关系。");
          if (feedback instanceof HTMLElement) {
            feedback.textContent = feedbackText;
          }
          quizState.answers[quizState.currentIndex] = {
            selectedLabel,
            isCorrect: false,
            feedbackText
          };
          window.setTimeout(() => {
            button.classList.remove("is-wrong");
          }, 520);
        });
      });
      bindQuizNav();
    };

    const generateQuiz = async (material) => {
      const currentGeneration = quizState.generationId + 1;

      quizState.generationId = currentGeneration;
      quizState.isLoading = true;
      quizState.cards = [];
      quizState.answers = [];
      quizState.currentIndex = 0;
      renderQuizLoading();

      try {
        const response = await fetch("/api/rio/generate-quiz", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            material: {
              id: material.id,
              type: material.type,
              text: material.text
            }
          })
        });
        const data = await response.json().catch(() => ({}));

        if (currentGeneration !== quizState.generationId) return;

        if (!response.ok) {
          throw new Error(data.error ?? "Quiz 生成失败，请稍后重试。");
        }

        quizState.cards = Array.isArray(data.cards) ? data.cards : [];
        const expectedCount = getQuizExpectedCount(material);
        if (quizState.cards.length !== expectedCount) {
          throw new Error(`AI 没有返回完整的 ${expectedCount} 张 Quiz 卡片。`);
        }

        renderQuizCard();
      } catch (error) {
        if (currentGeneration !== quizState.generationId) return;

        renderQuizError(error instanceof Error ? error.message : "Quiz 生成失败，请稍后重试。");
      } finally {
        if (currentGeneration === quizState.generationId) {
          quizState.isLoading = false;
        }
      }
    };

    const renderBadges = (groups) => {
      if (!(badgesBox instanceof HTMLElement)) return;

      badgesBox.innerHTML = groups
        .flatMap((group) =>
          group.items.map(
            (item) =>
              `<span class="rio-material-badge ${group.type}" title="${escapeHtml(
                group.type
              )}: ${escapeHtml(item.text)}">${escapeHtml(item.text)}</span>`
          )
        )
        .join("");
    };

    const showPage = (page) => {
      modalState.page = page;
      pages.forEach((item) => {
        item.hidden = item.getAttribute("data-rio-page") !== String(page);
      });

      if (modalTitle instanceof HTMLElement) {
        modalTitle.textContent =
          page === 1 ? "随机生成短文" : page === 2 ? "按照给定中文短文" : "语法检查";
      }
    };

    const parseStreamEvent = (chunk, handlers) => {
      const blocks = chunk.split("\n\n");
      const rest = blocks.pop() ?? "";

      blocks.forEach((block) => {
        const eventLine = block.split("\n").find((line) => line.startsWith("event:"));
        const dataLine = block.split("\n").find((line) => line.startsWith("data:"));
        if (!eventLine || !dataLine) return;

        const event = eventLine.slice(6).trim();
        const rawData = dataLine.slice(5).trim();

        try {
          handlers[event]?.(JSON.parse(rawData));
        } catch {
          handlers.error?.("AI 返回内容解析失败。");
        }
      });

      return rest;
    };

    const generatePassage = async () => {
      if (!(passageBox instanceof HTMLElement)) return;

      const currentGeneration = generationId + 1;
      generationId = currentGeneration;
      activeController?.abort?.();
      activeController = new AbortController();

      if (badgesBox instanceof HTMLElement) {
        badgesBox.innerHTML = "";
      }
      passageBox.textContent = "";
      passageBox.classList.add("is-loading");
      openButton?.setAttribute("disabled", "");

      try {
        const response = await fetch("/api/rio/generate", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            selected: getSelectedPayload()
          }),
          signal: activeController.signal
        });

        if (currentGeneration !== generationId) return;

        if (!response.ok || !response.body) {
          const data = await response.json().catch(() => ({}));
          throw new Error(data.error ?? "生成失败，请稍后重试。");
        }

        activeReader = response.body.getReader();
        const decoder = new TextDecoder();
        let buffer = "";
        let hasPackage = false;

        while (true) {
          const { done, value } = await activeReader.read();
          if (currentGeneration !== generationId) return;
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          buffer = parseStreamEvent(buffer, {
            package: (data) => {
              if (currentGeneration !== generationId) return;

              if (!Array.isArray(data.challenges)) {
                throw new Error("AI 返回的训练包不完整，请重新生成。");
              }

              hasPackage = true;
              modalState.materials = data.materials ?? null;
              modalState.trainingPackage = data;
              modalState.englishPassage = "";
              modalState.challenges = data.challenges;
              modalState.userAnswers = data.challenges.map(() => "");
              passageBox.textContent = data.input_scene ? `场景：${data.input_scene}\n\n` : "";

              if (modalState.materials) {
                renderBadges(modalState.materials);
              }
            },
            delta: (text) => {
              if (currentGeneration !== generationId) return;

              modalState.englishPassage += text;
              passageBox.textContent += text;
            },
            done: () => {},
            error: (message) => {
              throw new Error(message);
            }
          });
        }

        if (!hasPackage || !modalState.englishPassage.trim()) {
          throw new Error("AI 返回的训练包不完整，请重新生成。");
        }
      } catch (error) {
        if (error instanceof DOMException && error.name === "AbortError") return;
        if (currentGeneration !== generationId) return;

        if (badgesBox instanceof HTMLElement) {
          badgesBox.innerHTML = `<span class="rio-material-badge adverb">${escapeHtml(
            error instanceof Error ? error.message : "生成失败，请稍后重试。"
          )}</span>`;
        }
      } finally {
        if (currentGeneration === generationId) {
          passageBox.classList.remove("is-loading");
          openButton?.removeAttribute("disabled");
          activeReader = undefined;
          activeController = undefined;
        }
      }
    };

    const renderChallenges = () => {
      if (!(challengeList instanceof HTMLElement)) return;

      if (!Array.isArray(modalState.challenges) || !modalState.challenges.length) {
        challengeList.innerHTML =
          '<p class="rio-analysis-placeholder">中文翻译小题还没有生成，请回到上一页重新生成。</p>';
        return;
      }

      challengeList.innerHTML = modalState.challenges
        .map((challenge, index) => {
          const hints = Array.isArray(challenge.required_items)
            ? challenge.required_items
                .map(
                  (item) =>
                    `<span class="rio-material-badge ${escapeHtml(item.type)}">${escapeHtml(
                      item.text
                    )}</span>`
                )
                .join("")
            : "";

          return `<article class="rio-challenge-card">
            <h3>Sentence ${escapeHtml(challenge.index ?? index + 1)} <span class="rio-challenge-scene">${escapeHtml(
              challenge.scene ?? ""
            )}</span></h3>
            <p>${escapeHtml(challenge.chinese_prompt ?? "")}</p>
            <details class="rio-challenge-hint">
              <summary>查看目标元素</summary>
              <div class="rio-challenge-hint-list">${hints}</div>
            </details>
            <textarea
              class="rio-challenge-answer"
              data-rio-challenge-answer
              data-rio-challenge-index="${index}"
              rows="3"
              placeholder="输入你的英文翻译..."
            >${escapeHtml(modalState.userAnswers[index] ?? "")}</textarea>
          </article>`;
        })
        .join("");

      challengeList.querySelectorAll("[data-rio-challenge-answer]").forEach((textarea) => {
        textarea.addEventListener("input", () => {
          if (!(textarea instanceof HTMLTextAreaElement)) return;

          const index = Number(textarea.getAttribute("data-rio-challenge-index"));
          modalState.userAnswers[index] = textarea.value;

          if (inputError instanceof HTMLElement) {
            inputError.hidden = modalState.userAnswers.every((answer) => answer.trim());
          }

          if (modalState.analysis) {
            modalState.analysis = null;
            updateGrammarButtonLabel();
            if (analysisList instanceof HTMLElement) {
              analysisList.innerHTML =
                '<p class="rio-analysis-placeholder">回答已修改，请再次进行语法检查。</p>';
            }
          }
        });
      });
    };

    addButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLButtonElement)) return;

        const type = button.getAttribute("data-rio-item-type");
        const id = Number(button.getAttribute("data-rio-item-id"));
        const text = button.getAttribute("data-rio-item-text") ?? "";

        if (!type || !Number.isFinite(id) || !(type in selectedTargets)) return;

        const selectedItems = selectedTargets[type];
        const existingIndex = selectedItems.findIndex((item) => item.id === id);

        if (existingIndex >= 0) {
          selectedItems.splice(existingIndex, 1);
          updateSelectionUi();
          return;
        }

        if (selectedItems.length >= (selectionRequirements[type] ?? 0)) return;

        selectedItems.push({ id, text });
        updateSelectionUi();
      });
    });

    const renderAnalysis = (analyses) => {
      if (!(analysisList instanceof HTMLElement)) return;

      if (!Array.isArray(analyses) || !analyses.length) {
        analysisList.innerHTML =
          '<p class="rio-analysis-placeholder">AI 没有返回可用的语法检查结果。</p>';
        return;
      }

      analysisList.innerHTML = analyses
        .map(
          (analysis) => `<article class="rio-analysis-card">
            <h3>Sentence ${escapeHtml(analysis.sentence_index ?? "-")} ${
              analysis.scene ? `<span class="rio-challenge-scene">${escapeHtml(analysis.scene)}</span>` : ""
            }</h3>
            <section>
              <h4>中文题目</h4>
              <p>${escapeHtml(analysis.chinese_prompt ?? "")}</p>
            </section>
            <section>
              <h4>用户原句</h4>
              <p>${escapeHtml(analysis.user_sentence ?? "")}</p>
            </section>
            <section>
              <h4>目标元素使用</h4>
              <p>${escapeHtml(analysis.target_usage ?? "")}</p>
            </section>
            <section>
              <h4>语法问题</h4>
              <ul>
                ${(Array.isArray(analysis.grammar_issues) ? analysis.grammar_issues : [])
                  .map((issue) => `<li>${escapeHtml(issue)}</li>`)
                  .join("")}
              </ul>
            </section>
            <section>
              <h4>地道表达建议</h4>
              <p>${escapeHtml(analysis.idiomatic_suggestion ?? "")}</p>
            </section>
            <section>
              <h4>示例句</h4>
              <p>${escapeHtml(analysis.example_sentence ?? "")}</p>
            </section>
          </article>`
        )
        .join("");
    };

    const checkGrammar = async () => {
      if (
        !(analysisList instanceof HTMLElement) ||
        !modalState.materials ||
        !modalState.challenges.length ||
        modalState.isCheckingGrammar
      ) {
        return;
      }

      modalState.isCheckingGrammar = true;
      analysisList.innerHTML = '<p class="rio-analysis-placeholder">正在检查语法...</p>';

      try {
        const response = await fetch("/api/rio/check-grammar", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            challenges: modalState.challenges,
            user_answers: modalState.userAnswers.map((answer) => answer.trim()),
            materials: modalState.materials
          })
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(data.error ?? "语法检查失败，请稍后重试。");
        }

        modalState.analysis = data.analyses ?? [];
        renderAnalysis(modalState.analysis);
        updateGrammarButtonLabel();
      } catch (error) {
        analysisList.innerHTML = `<p class="rio-analysis-placeholder">${escapeHtml(
          error instanceof Error ? error.message : "语法检查失败，请稍后重试。"
        )}</p>`;
      } finally {
        modalState.isCheckingGrammar = false;
      }
    };

    openButton?.addEventListener("click", openModal);
    closeButtons.forEach((button) => button.addEventListener("click", closeModal));
    quizMaterialButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;

        const material = {
          id: Number(button.getAttribute("data-rio-material-id")),
          type: button.getAttribute("data-rio-material-type") ?? "",
          text: button.getAttribute("data-rio-material-text") ?? ""
        };

        if (!Number.isFinite(material.id) || !material.type || !material.text) return;
        openQuizModal(material);
      });
    });
    quizCloseButtons.forEach((button) => button.addEventListener("click", closeQuizModal));
    pageButtons.next?.addEventListener("click", () => {
      showPage(2);
      renderChallenges();
    });
    pageButtons.prev?.addEventListener("click", () => {
      showPage(1);
    });
    pageButtons.grammarCheck?.addEventListener("click", () => {
      const isComplete =
        modalState.userAnswers.length === modalState.challenges.length &&
        modalState.userAnswers.every((answer) => answer.trim());

      if (inputError instanceof HTMLElement) {
        inputError.hidden = Boolean(isComplete);
      }

      if (!isComplete) return;

      showPage(3);

      if (modalState.analysis) {
        renderAnalysis(modalState.analysis);
        return;
      }

      checkGrammar();
    });
    pageButtons.backToAnswer?.addEventListener("click", () => {
      showPage(2);
    });
    pageButtons.complete?.addEventListener("click", launchCompletionCelebration);
    updateSelectionUi();

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;

      if (quizModal instanceof HTMLElement && !quizModal.hidden) {
        closeQuizModal();
        return;
      }

      if (modal instanceof HTMLElement && !modal.hidden) {
        closeModal();
      }
    });
  </script>
</BaseLayout>
