---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = false;

type EnglishItem = {
  id: number;
  type: string;
  text: string;
};

type D1PreparedStatement = {
  bind: (...values: unknown[]) => D1PreparedStatement;
  all: <T>() => Promise<{ results?: T[]; meta?: Record<string, unknown> }>;
  first: <T>() => Promise<T | null>;
};

type D1Database = {
  prepare: (query: string) => D1PreparedStatement;
};

const sections = [
  { title: "Chunks", type: "chunk", required: 3 },
  { title: "Sentence Patterns", type: "sentence_pattern", required: 1 },
  { title: "Vocabulary", type: "vocabulary", required: 2 },
  { title: "Adverbs", type: "adverb", required: 1 }
] as const;

const db = (Astro.locals as any).runtime?.env?.DB as D1Database | undefined;

let dbStatus: "success" | "missing" | "error" = "missing";
let dbError = "";
let totalCount = 0;
let items: EnglishItem[] = [];

if (db) {
  try {
    const itemsResult = await db
      .prepare(
        `SELECT id, type, text
         FROM english_items
         WHERE type IN (?, ?, ?, ?)
         ORDER BY
           CASE type
             WHEN 'chunk' THEN 1
             WHEN 'sentence_pattern' THEN 2
             WHEN 'vocabulary' THEN 3
             WHEN 'adverb' THEN 4
             ELSE 5
           END,
           id ASC`
      )
      .bind(...sections.map((section) => section.type))
      .all<EnglishItem>();

    dbStatus = "success";
    items = itemsResult.results ?? [];
    totalCount = items.length;
  } catch (error) {
    dbStatus = "error";
    dbError = error instanceof Error ? error.message : "Unknown D1 query error";
  }
}

const itemsByType = sections.map((section) => ({
  ...section,
  items: items.filter((item) => item.type === section.type)
}));
---

<BaseLayout
  title="RIO"
  description="随机 chunk 输入输出一体化，用于练习与数据库能力测试。"
>
  <section class="rio-page">
    <div class="rio-head">
      <div class="rio-title-row">
        <h1>RIO</h1>
        <button class="rio-modal-trigger" type="button" data-rio-modal-open>
          随机生成
        </button>
      </div>
      <p>
        Random Input Output. 当前页面从 D1 一次性读取英语素材，并按类型分表展示。
      </p>
    </div>

    {
      dbStatus === "success" ? (
        <div class="rio-table-grid" aria-label="RIO 数据表">
          {itemsByType.map((section) => (
            <section class="rio-table-card">
              <div class="rio-table-head">
                <h2>{section.title}</h2>
                <div class="rio-table-meta">
                  <span>{section.items.length}</span>
                  <span data-rio-selection-progress={section.type}>0/{section.required}</span>
                </div>
              </div>
              {section.items.length ? (
                <table>
                  <thead>
                    <tr>
                      <th scope="col">ID</th>
                      <th scope="col">Text</th>
                      <th scope="col">Pick</th>
                    </tr>
                  </thead>
                  <tbody>
                    {section.items.map((item) => (
                      <tr data-rio-item-row={item.id}>
                        <td>{item.id}</td>
                        <td>
                          {["sentence_pattern", "chunk", "vocabulary", "adverb"].includes(item.type) ? (
                            <button
                              class="rio-quiz-material-button"
                              type="button"
                              data-rio-quiz-material
                              data-rio-material-id={item.id}
                              data-rio-material-type={item.type}
                              data-rio-material-text={item.text}
                            >
                              {item.text}
                            </button>
                          ) : (
                            item.text
                          )}
                        </td>
                        <td>
                          <button
                            class="rio-add-button"
                            type="button"
                            aria-label={`Add ${item.text}`}
                            data-rio-add-item
                            data-rio-item-id={item.id}
                            data-rio-item-type={item.type}
                            data-rio-item-text={item.text}
                          >
                            +
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              ) : (
                <p class="rio-empty">暂无数据。</p>
              )}
            </section>
          ))}
          <p class="rio-summary">共读取 {totalCount} 条记录。</p>
        </div>
      ) : (
        <div class="rio-panel">
          {dbStatus === "missing" ? (
            <p>
              当前运行环境没有拿到 <code>DB</code> 绑定。请用 Cloudflare 运行时预览或部署后访问本页测试。
            </p>
          ) : (
            <p>
              D1 查询失败：<code>{dbError}</code>
            </p>
          )}
        </div>
      )
    }

    <div class="rio-modal" hidden data-rio-modal>
      <div class="rio-modal-backdrop" data-rio-modal-close></div>
      <section
        class="rio-modal-card"
        role="dialog"
        aria-modal="true"
        aria-labelledby="rio-modal-title"
      >
        <div class="rio-modal-head">
          <div>
            <span>RIO</span>
            <div class="rio-modal-title-row">
              <h2 id="rio-modal-title">随机生成短文</h2>
              <div class="rio-material-badges" data-rio-material-badges></div>
            </div>
          </div>
          <button
            class="rio-modal-close"
            type="button"
            aria-label="关闭随机生成弹窗"
            data-rio-modal-close
          >
            ×
          </button>
        </div>
        <div class="rio-modal-body">
          <div class="rio-modal-page" data-rio-page="1">
            <article class="rio-generated-passage" data-rio-generated-passage>
              <p>AI 短文会在这里流式出现。</p>
            </article>
            <div class="rio-modal-actions">
              <button class="rio-next-button" type="button" data-rio-next>
                下一页
              </button>
            </div>
          </div>

          <div class="rio-modal-page" hidden data-rio-page="2">
            <div class="rio-challenge-list" data-rio-challenge-list>
              <p class="rio-analysis-placeholder">中文翻译小题会在这里显示。</p>
            </div>
            <p class="rio-input-error" hidden data-rio-input-error>
              请先完成全部 3 句翻译，再进行语法检查。
            </p>
            <div class="rio-modal-actions">
              <button class="rio-ghost-button" type="button" data-rio-prev>
                上一页
              </button>
              <button class="rio-next-button" type="button" data-rio-grammar-check>
                语法检查
              </button>
            </div>
          </div>

          <div class="rio-modal-page" hidden data-rio-page="3">
            <div class="rio-analysis-list" data-rio-analysis-list>
              <p class="rio-analysis-placeholder">语法检查结果会在这里显示。</p>
            </div>
            <div class="rio-modal-actions">
              <button class="rio-ghost-button" type="button" data-rio-back-to-answer>
                上一页
              </button>
              <button class="rio-next-button" type="button" data-rio-complete>
                完成
              </button>
            </div>
          </div>
        </div>
      </section>
      <div class="rio-celebration" hidden aria-hidden="true" data-rio-celebration></div>
    </div>

    <div class="rio-quiz-modal" hidden data-rio-quiz-modal>
      <div class="rio-modal-backdrop" data-rio-quiz-close></div>
      <section
        class="rio-modal-card rio-quiz-card"
        role="dialog"
        aria-modal="true"
        aria-labelledby="rio-quiz-title"
      >
        <div class="rio-modal-head">
          <div>
            <span>RIO</span>
            <div class="rio-modal-title-row">
              <h2 id="rio-quiz-title">Quiz</h2>
              <div class="rio-material-badges" data-rio-quiz-material-badge></div>
            </div>
          </div>
          <button
            class="rio-modal-close"
            type="button"
            aria-label="Close quiz"
            data-rio-quiz-close
          >
            ×
          </button>
        </div>
        <div class="rio-modal-body">
          <div class="rio-quiz-stage" data-rio-quiz-stage>
            <p class="rio-analysis-placeholder">Quiz will appear here.</p>
          </div>
        </div>
      </section>
    </div>
  </section>

  <style>
    .rio-page {
      padding: 58px 0 88px;
    }

    .rio-head {
      max-width: 760px;
      padding-bottom: 34px;
    }

    .rio-title-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }

    .rio-head h1 {
      margin: 0;
      font-size: clamp(38px, 6vw, 64px);
    }

    .rio-head p {
      max-width: 680px;
      margin: 0;
      color: var(--muted);
      font-size: 18px;
    }

    .rio-modal-trigger,
    .rio-modal-close {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--line);
      background: var(--surface);
      color: var(--text);
      font: inherit;
      font-weight: 850;
      cursor: pointer;
      transition:
        border-color 160ms ease,
        background 160ms ease,
        color 160ms ease,
        box-shadow 160ms ease;
    }

    .rio-modal-trigger {
      min-height: 42px;
      border-radius: 8px;
      padding: 0 16px;
      font-size: 14px;
    }

    .rio-modal-trigger:hover,
    .rio-modal-trigger:focus-visible,
    .rio-modal-close:hover,
    .rio-modal-close:focus-visible {
      border-color: var(--text);
      background: var(--text);
      color: var(--bg);
      outline: none;
    }

    .rio-panel,
    .rio-table-card {
      border: 1px solid var(--line);
      border-radius: 10px;
      background: color-mix(in srgb, var(--surface) 90%, transparent);
      padding: 24px;
    }

    .rio-panel h2 {
      margin: 8px 0 8px;
      font-size: 24px;
    }

    .rio-panel p {
      max-width: 620px;
      margin: 0;
      color: var(--muted);
    }

    .rio-panel code {
      border-radius: 5px;
      background: var(--surface-soft);
      padding: 2px 5px;
      color: var(--text);
      font-size: 0.9em;
    }

    .rio-table-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .rio-table-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
    }

    .rio-table-head h2 {
      margin: 0;
      font-size: 24px;
    }

    .rio-table-meta {
      display: inline-flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 6px;
    }

    .rio-table-head span {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      border-radius: 8px;
      background: var(--surface-soft);
      padding: 0 10px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 750;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    th,
    td {
      border-top: 1px solid var(--line);
      padding: 10px 0;
      text-align: left;
      vertical-align: top;
    }

    th {
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
      text-transform: uppercase;
    }

    th:first-child,
    td:first-child {
      width: 54px;
      color: var(--muted);
    }

    th:last-child,
    td:last-child {
      width: 58px;
      text-align: right;
    }

    td {
      color: var(--text);
      overflow-wrap: anywhere;
    }

    .rio-quiz-material-button {
      width: 100%;
      border: 0;
      background: transparent;
      color: var(--text);
      padding: 0;
      font: inherit;
      text-align: left;
      cursor: pointer;
      text-decoration: underline;
      text-decoration-color: color-mix(in srgb, var(--accent) 36%, transparent);
      text-decoration-thickness: 2px;
      text-underline-offset: 4px;
    }

    .rio-quiz-material-button:hover,
    .rio-quiz-material-button:focus-visible {
      color: var(--accent);
      outline: none;
    }

    .rio-add-button {
      width: 30px;
      height: 30px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      font-size: 20px;
      font-weight: 800;
      line-height: 1;
      cursor: pointer;
    }

    .rio-add-button:hover,
    .rio-add-button:focus-visible {
      border-color: color-mix(in srgb, var(--accent) 70%, var(--line));
      color: var(--accent);
      outline: none;
    }

    .rio-add-button.is-selected {
      border-color: color-mix(in srgb, var(--accent) 70%, var(--line));
      background: color-mix(in srgb, var(--accent) 12%, var(--surface));
      color: var(--accent);
    }

    .rio-add-button:disabled {
      cursor: not-allowed;
      opacity: 0.38;
    }

    .rio-empty {
      margin: 0;
      color: var(--muted);
    }

    .rio-summary {
      grid-column: 1 / -1;
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 15px;
    }

    .rio-modal[hidden] {
      display: none;
    }

    .rio-quiz-modal[hidden] {
      display: none;
    }

    .rio-modal,
    .rio-quiz-modal {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: grid;
      place-items: center;
      padding: 24px;
    }

    .rio-modal.is-opening .rio-modal-backdrop {
      animation: rio-modal-backdrop-in 180ms ease both;
    }

    .rio-modal.is-closing .rio-modal-backdrop {
      animation: rio-modal-backdrop-out 180ms ease both;
    }

    .rio-modal-backdrop {
      position: absolute;
      inset: 0;
      background: color-mix(in srgb, var(--bg) 72%, transparent);
      backdrop-filter: blur(8px);
    }

    .rio-modal-card {
      position: relative;
      z-index: 1;
      width: min(780px, 100%);
      max-height: min(760px, calc(100vh - 48px));
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--surface);
      padding: 22px;
      box-shadow: 0 24px 80px color-mix(in srgb, var(--text) 18%, transparent);
    }

    .rio-modal.is-opening .rio-modal-card {
      animation: rio-modal-pop-in 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .rio-modal.is-closing .rio-modal-card {
      animation: rio-modal-pop-out 180ms ease-in both;
    }

    .rio-quiz-modal.is-opening .rio-modal-backdrop {
      animation: rio-modal-backdrop-in 180ms ease both;
    }

    .rio-quiz-modal.is-opening .rio-modal-card {
      animation: rio-modal-pop-in 220ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .rio-quiz-card {
      width: min(720px, 100%);
    }

    .rio-modal-card.is-celebrating {
      overflow: hidden;
    }

    .rio-modal-card.is-celebrating::after {
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background:
        radial-gradient(circle at 50% 24%, color-mix(in srgb, #fbbf24 18%, transparent), transparent 30%),
        color-mix(in srgb, var(--surface) 10%, transparent);
      content: "";
      pointer-events: none;
      animation: rio-celebration-glow 980ms ease forwards;
    }

    .rio-celebration {
      position: fixed;
      inset: 0;
      z-index: 2;
      overflow: hidden;
      pointer-events: none;
    }

    .rio-celebration[hidden] {
      display: none;
    }

    :global(.rio-confetti-piece) {
      position: absolute;
      top: var(--confetti-origin-y);
      left: var(--confetti-origin-x);
      width: var(--confetti-width);
      height: var(--confetti-height);
      z-index: 3;
      border-radius: 2px;
      background: var(--confetti-color);
      opacity: 0;
      transform: translate(-50%, -50%) rotate(var(--confetti-spin));
      animation: rio-confetti-burst var(--confetti-duration) cubic-bezier(0.15, 0.8, 0.35, 1) forwards;
      animation-delay: var(--confetti-delay);
    }

    @keyframes rio-celebration-glow {
      0% {
        opacity: 0;
      }

      22% {
        opacity: 1;
      }

      100% {
        opacity: 0;
      }
    }

    @keyframes rio-modal-backdrop-in {
      0% {
        opacity: 0;
      }

      100% {
        opacity: 1;
      }
    }

    @keyframes rio-modal-backdrop-out {
      0% {
        opacity: 1;
      }

      100% {
        opacity: 0;
      }
    }

    @keyframes rio-modal-pop-in {
      0% {
        opacity: 0;
        transform: scale(0.94);
      }

      70% {
        opacity: 1;
        transform: scale(1.012);
      }

      100% {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes rio-modal-pop-out {
      0% {
        opacity: 1;
        transform: scale(1);
      }

      100% {
        opacity: 0;
        transform: scale(0.96);
      }
    }

    @keyframes rio-confetti-burst {
      0% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8) rotate(var(--confetti-spin));
      }

      12% {
        opacity: 1;
      }

      100% {
        opacity: 0;
        transform:
          translate(
            calc(-50% + var(--confetti-x)),
            calc(-50% + var(--confetti-y))
          )
          scale(var(--confetti-scale))
          rotate(calc(var(--confetti-spin) + var(--confetti-rotation)));
      }
    }

    .rio-modal-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 20px;
      border-bottom: 1px solid var(--line);
      padding-bottom: 16px;
    }

    .rio-modal-head span {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 850;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .rio-modal-head h2 {
      margin: 0;
      font-size: 26px;
    }

    .rio-modal-close {
      flex: 0 0 auto;
      width: 38px;
      height: 38px;
      border-radius: 8px;
      font-size: 24px;
      line-height: 1;
    }

    .rio-modal-body {
      padding-top: 18px;
    }

    .rio-modal-body p {
      margin: 0;
      color: var(--muted);
    }

    .rio-modal-page {
      display: grid;
      gap: 16px;
    }

    .rio-modal-page[hidden] {
      display: none;
    }

    .rio-modal-title-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px 12px;
    }

    .rio-material-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      max-width: min(100%, 520px);
    }

    :global(.rio-material-badge) {
      display: inline-flex;
      align-items: center;
      max-width: 180px;
      min-height: 24px;
      border: 1px solid currentColor;
      border-radius: 999px;
      padding: 2px 8px;
      font-size: 12px;
      font-weight: 800;
      line-height: 1.3;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    :global(.rio-material-badge.chunk) {
      background: color-mix(in srgb, #e5484d 12%, transparent);
      color: #c92a2a;
    }

    :global(.rio-material-badge.sentence_pattern) {
      background: color-mix(in srgb, #3b82f6 12%, transparent);
      color: #2563eb;
    }

    :global(.rio-material-badge.vocabulary) {
      background: color-mix(in srgb, #22c55e 12%, transparent);
      color: #15803d;
    }

    :global(.rio-material-badge.adverb) {
      background: color-mix(in srgb, #a855f7 12%, transparent);
      color: #7e22ce;
    }

    .rio-generated-passage {
      min-height: 260px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--surface) 92%, transparent);
      padding: 18px;
      color: var(--text);
      font-size: 17px;
      line-height: 1.8;
      white-space: pre-wrap;
    }

    .rio-generated-passage.is-loading::after {
      display: inline-block;
      width: 8px;
      height: 1.2em;
      margin-left: 2px;
      background: var(--text);
      content: "";
      vertical-align: -0.2em;
      animation: rio-caret 900ms steps(1) infinite;
    }

    @keyframes rio-caret {
      50% {
        opacity: 0;
      }
    }

    .rio-modal-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
    }

    .rio-challenge-list {
      display: grid;
      gap: 12px;
    }

    :global(.rio-challenge-card) {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--surface) 92%, transparent);
      padding: 16px;
    }

    :global(.rio-challenge-card h3) {
      margin: 0 0 8px;
      font-size: 16px;
    }

    :global(.rio-challenge-card p) {
      margin: 0 0 12px;
      color: var(--text);
      line-height: 1.7;
    }

    :global(.rio-challenge-scene) {
      display: inline-flex;
      align-items: center;
      min-height: 24px;
      border-radius: 8px;
      background: var(--surface-soft);
      padding: 0 8px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 850;
    }

    :global(.rio-challenge-hint) {
      margin: 8px 0 12px;
    }

    :global(.rio-challenge-hint summary) {
      color: var(--muted);
      cursor: pointer;
      font-size: 13px;
      font-weight: 800;
    }

    :global(.rio-challenge-hint-list) {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }

    :global(.rio-challenge-answer) {
      width: 100%;
      min-height: 86px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      padding: 12px 14px;
      font: inherit;
      line-height: 1.6;
      outline: none;
      resize: vertical;
    }

    .rio-answer-panel textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      padding: 14px 16px;
      font: inherit;
      line-height: 1.65;
      outline: none;
      resize: vertical;
    }

