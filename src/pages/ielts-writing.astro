---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="IELTS Writing Lab"
  description="雅思写作底层能力练习：逐句拆解、回译训练与 AI 分析检查。"
>
  <section class="writing-lab" data-writing-lab>
    <div class="lab-hero">
      <p class="eyebrow">IELTS Writing Lab</p>
      <h1>SRT Console</h1>
      <p>
        Sentence Reverse Translation Console. 粘贴一篇英文范文，先拆成中文句子，
        再逐句翻回英文。最后用 AI 对照原文、你的表达和建议版本，沉淀语法、
        表达、chunk 与句型。
      </p>
    </div>

    <div class="lab-panel input-panel">
      <div class="panel-head">
        <div>
          <span class="step">01</span>
          <div class="panel-title-row">
            <h2>粘贴范文</h2>
            <span>或</span>
            <select class="essay-category-select" data-essay-category aria-label="选择范文分类">
              <option value="">随机分类</option>
              <option value="Education" data-label="教育">教育</option>
              <option value="Technology" data-label="科技">科技</option>
              <option value="Work & Economy" data-label="工作与经济">工作与经济</option>
              <option value="Environment" data-label="环境">环境</option>
              <option value="Government & Law" data-label="政府与法律">政府与法律</option>
              <option value="Family & Children" data-label="家庭与儿童">家庭与儿童</option>
              <option value="Social Issues" data-label="社会问题">社会问题</option>
              <option value="Media & Advertising" data-label="媒体与广告">媒体与广告</option>
              <option value="Culture & Tradition" data-label="文化与传统">文化与传统</option>
              <option value="Globalisation" data-label="国际化与全球化">国际化与全球化</option>
              <option value="Health & Lifestyle" data-label="健康与生活方式">健康与生活方式</option>
            </select>
            <button class="primary-button" type="button" data-generate-essay>
              AI生成随机分类范文
            </button>
          </div>
        </div>
      </div>
      <textarea
        data-source-text
        rows="9"
        placeholder="在这里粘贴任意英文文章或雅思范文..."
      ></textarea>
      <div class="action-row">
        <p data-source-meta>等待输入文章</p>
        <button class="primary-button" type="button" data-split-text>AI 拆解为中文</button>
      </div>
    </div>

    <div class="lab-panel sentence-panel" hidden data-practice-panel>
      <div class="panel-head">
        <div>
          <span class="step">02</span>
          <h2>根据中文逐句回译</h2>
        </div>
        <span class="status-pill" data-sentence-count>0 句</span>
      </div>
      <div class="sentence-list" data-sentence-list></div>
      <div class="check-bar" data-check-bar>
        <button
          class="check-bar-toggle"
          type="button"
          data-check-bar-toggle
          aria-expanded="true"
        >
          隐藏检查栏
        </button>
        <div>
          <strong>完成后进行检查</strong>
          <p>选择要检查的句子序号，分析结果会出现在对应句子下面；不满意时可重新选择同一句再分析。</p>
        </div>
        <div class="analysis-control">
          <span>选择句子</span>
          <div class="sentence-picker" data-analysis-targets></div>
          <small>一次只能选择一句；点击序号会定位到对应句子。</small>
          <div class="check-actions">
            <button class="primary-button" type="button" data-analyze>AI 分析所选句子</button>
            <button class="ghost-button" type="button" data-export-pdf>导出为pdf</button>
          </div>
        </div>
      </div>
    </div>

    <div class="export-dialog" hidden data-export-dialog role="dialog" aria-modal="true" aria-labelledby="export-dialog-title">
      <div class="export-dialog-card">
        <div>
          <span class="step">导出检查</span>
          <h2 id="export-dialog-title">还有句子没有完成</h2>
          <p data-export-dialog-message>请先完成所有回译，再导出为 PDF。</p>
        </div>
        <button class="primary-button" type="button" data-export-dialog-close>我知道了</button>
      </div>
    </div>

    <article class="export-document" data-export-document aria-hidden="true"></article>
  </section>

  <style>
    .writing-lab {
      padding: 58px 0 88px;
    }

    .lab-hero {
      max-width: 760px;
      padding-bottom: 34px;
    }

    .eyebrow {
      margin: 0 0 10px;
      color: var(--accent);
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .lab-hero h1 {
      margin-bottom: 16px;
      font-size: clamp(38px, 6vw, 64px);
    }

    .lab-hero p {
      max-width: 680px;
      margin: 0;
      color: var(--muted);
      font-size: 18px;
    }

    .lab-panel {
      border: 1px solid var(--line);
      border-radius: 10px;
      background: color-mix(in srgb, var(--surface) 90%, transparent);
      padding: 24px;
    }

    .lab-panel + .lab-panel {
      margin-top: 18px;
    }

    .panel-head,
    .action-row,
    .check-bar,
    .analysis-row,
    .analysis-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .panel-head {
      margin-bottom: 18px;
    }

    .panel-title-row {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 4px;
    }

    .panel-head h2 {
      margin: 0;
      font-size: 24px;
    }

    .panel-title-row span {
      color: var(--muted);
      font-size: 15px;
      font-weight: 750;
    }

    .essay-category-select {
      min-height: 44px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      padding: 0 36px 0 12px;
      font: inherit;
      font-size: 14px;
      font-weight: 750;
      outline: none;
      cursor: pointer;
    }

    .essay-category-select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
    }

    .step,
    .status-pill,
    .analysis-tag {
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      border-radius: 8px;
      background: var(--surface-soft);
      padding: 0 10px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 750;
    }

    textarea,
    .answer-input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      padding: 14px 16px;
      outline: none;
      resize: vertical;
    }

    .answer-box {
      border: 1px solid var(--line);
      border-radius: 10px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--surface-soft) 56%, transparent),
          var(--surface) 34%
        );
      padding: 12px;
      transition:
        border-color 160ms ease,
        box-shadow 160ms ease,
        background 160ms ease;
    }

    .answer-box:focus-within {
      border-color: var(--accent);
      background: var(--surface);
      box-shadow: 0 12px 30px color-mix(in srgb, var(--accent) 14%, transparent);
    }

    .answer-box-head,
    .answer-box-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 0 2px;
    }

    .answer-box-head {
      margin-bottom: 9px;
    }

    .answer-box-head span {
      color: var(--text);
      font-size: 14px;
      font-weight: 850;
    }

    .answer-box-head small,
    .answer-box-foot {
      color: var(--muted);
      font-size: 12px;
      font-weight: 650;
    }

    .answer-box-foot {
      justify-content: flex-end;
      margin-top: 8px;
      line-height: 1.45;
    }

    .answer-box .answer-input {
      display: block;
      min-height: 118px;
      border-color: transparent;
      background: color-mix(in srgb, var(--surface) 92%, transparent);
      padding: 15px 16px;
      line-height: 1.65;
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--line) 76%, transparent);
    }

    .answer-box .answer-input::placeholder {
      color: color-mix(in srgb, var(--muted) 70%, transparent);
    }

    .answer-box .answer-input:focus {
      border-color: transparent;
      box-shadow:
        inset 0 0 0 1px var(--accent),
        0 0 0 3px color-mix(in srgb, var(--accent) 14%, transparent);
    }

    textarea:focus,
    .answer-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
    }

    .action-row {
      margin-top: 14px;
    }

    .action-row p,
    .check-bar p {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
    }

    .action-row p {
      min-width: 0;
      white-space: pre-line;
    }

    .primary-button,
    .ghost-button {
      min-height: 44px;
      border-radius: 8px;
      padding: 0 18px;
      font-weight: 800;
      white-space: nowrap;
      cursor: pointer;
    }

    .primary-button {
      border: 0;
      background: var(--text);
      color: var(--bg);
    }

    .ghost-button {
      border: 1px solid var(--line);
      background: transparent;
      color: var(--text);
    }

    .sentence-list {
      display: grid;
      gap: 14px;
    }

    .sentence-card {
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--surface);
      padding: 18px;
    }

    .sentence-card header {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 14px;
    }

    .sentence-number {
      display: grid;
      flex: 0 0 34px;
      width: 34px;
      height: 34px;
      place-items: center;
      border-radius: 8px;
      background: var(--text);
      color: var(--bg);
      font-size: 14px;
      font-weight: 850;
    }

    .chinese-line {
      margin: 0;
      color: var(--text);
      font-size: 18px;
      font-weight: 750;
      line-height: 1.55;
    }

    .answer-input {
      min-height: 92px;
    }

    .check-bar {
      position: sticky;
      bottom: 16px;
      margin-top: 18px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: color-mix(in srgb, var(--surface) 96%, transparent);
      padding: 16px;
      box-shadow: 0 14px 34px rgba(0, 0, 0, 0.08);
    }

    .check-bar strong {
      display: block;
      margin-bottom: 2px;
    }

    .check-bar-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      order: 3;
      align-self: flex-start;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface-soft);
      color: var(--text);
      padding: 10px 12px;
      font: inherit;
      font-size: 13px;
      font-weight: 850;
      min-width: 108px;
      white-space: nowrap;
      cursor: pointer;
    }

    .check-bar.is-collapsed {
      align-items: flex-end;
      width: fit-content;
      max-width: 100%;
      margin-left: auto;
      padding: 8px;
    }

    .check-bar.is-collapsed > :not(.check-bar-toggle) {
      display: none;
    }

    .check-bar.is-collapsed .check-bar-toggle {
      position: static;
      width: auto;
      min-width: 108px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    }

    .check-bar.is-collapsing {
      animation: check-bar-collapse 180ms ease both;
    }

    .check-bar.is-expanding {
      animation: check-bar-expand 220ms ease both;
    }

    @keyframes check-bar-collapse {
      from {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      to {
        opacity: 0.88;
        transform: translateY(8px) scale(0.97);
      }
    }

    @keyframes check-bar-expand {
      from {
        opacity: 0.88;
        transform: translateY(8px) scale(0.97);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .check-bar.is-collapsing,
      .check-bar.is-expanding {
        animation: none;
      }
    }

    .analysis-control {
      display: grid;
      min-width: min(100%, 310px);
      gap: 10px;
    }

    .check-actions {
      display: grid;
      gap: 10px;
    }

    .analysis-control span,
    .analysis-control small {
      color: var(--muted);
      font-size: 13px;
      font-weight: 750;
    }

    .sentence-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      max-width: 360px;
    }

    .sentence-picker button {
      display: grid;
      position: relative;
      min-width: 38px;
      height: 38px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 8px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--surface-soft) 70%, transparent),
          var(--surface)
        );
      color: var(--text);
      font: inherit;
      font-size: 14px;
      font-weight: 850;
      cursor: pointer;
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        box-shadow 160ms ease,
        background 160ms ease,
        color 160ms ease;
    }

    .sentence-picker button:hover,
    .sentence-picker button:focus-visible {
      border-color: var(--accent);
      transform: translateY(-1px);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
    }

    .sentence-picker button.is-selected {
      border-color: var(--accent);
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--accent) 24%, var(--text)),
          var(--text)
        );
      color: var(--bg);
      box-shadow:
        0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent),
        0 10px 22px color-mix(in srgb, var(--text) 14%, transparent);
      transform: translateY(-1px);
    }

    .sentence-picker button.is-selected::after {
      content: "✓";
      position: absolute;
      top: -7px;
      right: -7px;
      display: grid;
      width: 18px;
      height: 18px;
      place-items: center;
      border: 2px solid var(--surface);
      border-radius: 999px;
      background: var(--accent);
      color: var(--bg);
      font-size: 11px;
      line-height: 1;
    }

    .sentence-picker button span {
      position: relative;
      z-index: 1;
    }

    .analysis-box {
      display: grid;
      gap: 14px;
      margin-top: 16px;
      border-top: 1px solid var(--line);
      padding-top: 16px;
    }

    .analysis-section {
      border-radius: 8px;
      background: var(--surface-soft);
      padding: 14px;
    }

    .analysis-section h3 {
      margin: 0 0 8px;
      font-size: 16px;
    }

    .analysis-section p,
    .analysis-section li {
      color: var(--muted);
      font-size: 15px;
      line-height: 1.65;
    }

    .analysis-section p,
    .analysis-section ul {
      margin: 0;
    }

    .analysis-section ul {
      padding-left: 20px;
    }

    .compare-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .compare-item {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      padding: 12px;
    }

    .compare-item span {
      display: block;
      margin-bottom: 5px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .compare-item p {
      color: var(--text);
    }

    .error-message {
      margin: 12px 0 0;
      border: 1px solid color-mix(in srgb, #d33 42%, var(--line));
      border-radius: 8px;
      background: color-mix(in srgb, #d33 8%, var(--surface));
      padding: 10px 12px;
      color: #b42318;
      font-size: 14px;
    }

    .export-dialog {
      position: fixed;
      inset: 0;
      z-index: 20;
      display: grid;
      place-items: center;
      background: rgba(0, 0, 0, 0.28);
      padding: 20px;
    }

    .export-dialog[hidden] {
      display: none;
    }

    .export-dialog-card {
      display: grid;
      width: min(100%, 420px);
      gap: 18px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--surface);
      padding: 22px;
      box-shadow: 0 22px 70px rgba(0, 0, 0, 0.18);
    }

    .export-dialog-card h2 {
      margin: 12px 0 8px;
      font-size: 24px;
    }

    .export-dialog-card p {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.7;
    }

    .export-document {
      display: none;
    }

    @media print {
      @page {
        margin: 16mm;
      }

      body.is-exporting-pdf > * {
        display: none;
      }

      body.is-exporting-pdf {
        display: block;
        background: #fff;
      }

      body.is-exporting-pdf main,
      body.is-exporting-pdf .writing-lab,
      body.is-exporting-pdf .export-document.is-exporting {
        display: block;
      }

      body.is-exporting-pdf .writing-lab > :not(.export-document) {
        display: none;
      }

      .export-document.is-exporting {
        display: block;
        width: 100%;
        color: #111;
        background: #fff;
        font-family:
          "Inter", "Noto Sans SC", "Microsoft YaHei", Arial, sans-serif;
        font-size: 12px;
        line-height: 1.65;
      }

      .export-document h1,
      .export-document h2,
      .export-document h3,
      .export-document p {
        margin-top: 0;
      }

      .export-document h1 {
        margin-bottom: 10px;
        font-size: 24px;
      }

      .export-document h2 {
        margin: 22px 0 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid #ddd;
        font-size: 18px;
      }

      .export-document h3 {
        margin: 16px 0 8px;
        font-size: 15px;
      }

      .export-document p,
      .export-document li {
        color: #222;
      }

      .export-source,
      .export-sentence {
        break-inside: avoid;
        margin-bottom: 16px;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 14px;
      }

      .export-label {
        display: inline-block;
        margin-bottom: 6px;
        color: #666;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .export-user-answer {
        white-space: pre-wrap;
      }

      .export-analysis {
        margin-top: 12px;
        border-top: 1px solid #e5e5e5;
        padding-top: 12px;
      }

      .export-analysis .analysis-section {
        margin-top: 10px;
        background: #f7f7f7;
        padding: 10px;
      }

      .export-analysis table {
        display: table;
        width: 100%;
        border-collapse: collapse;
      }

      .export-analysis th,
      .export-analysis td {
        border: 1px solid #ddd;
        padding: 8px;
      }

      .export-analysis pre {
        white-space: pre-wrap;
        border: 1px solid #ddd;
        background: #f7f7f7;
        padding: 10px;
      }
    }

    @media (max-width: 760px) {
      .writing-lab {
        padding-top: 36px;
      }

      .lab-panel {
        padding: 18px;
      }

      .panel-head,
      .action-row,
      .check-bar {
        align-items: stretch;
        flex-direction: column;
      }

      .primary-button,
      .ghost-button {
        width: 100%;
      }

      .compare-grid {
        grid-template-columns: 1fr;
      }

      .check-bar {
        bottom: 10px;
        gap: 12px;
        max-height: min(68vh, 560px);
        overflow-y: auto;
        padding-top: 10px;
        overscroll-behavior: contain;
        transform-origin: right bottom;
      }

      .check-bar-toggle {
        position: sticky;
        top: 0;
        z-index: 2;
        align-self: flex-end;
        order: 0;
        width: auto;
        padding: 6px 9px;
        font-size: 12px;
        box-shadow: 0 8px 16px color-mix(in srgb, var(--surface) 78%, transparent);
      }

      .check-bar.is-collapsed {
        max-width: calc(100vw - 36px);
      }

      .check-bar.is-collapsed .check-bar-toggle {
        align-self: auto;
      }

    }
  </style>

  <style is:global>
    @media print {
      body.is-exporting-pdf .site-header .header-actions {
        display: none !important;
      }
    }

    .writing-lab .sentence-card {
      position: relative;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--surface);
      padding: 18px;
    }

    .writing-lab .sentence-card header {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 14px;
    }

    .writing-lab .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
    }

    .writing-lab .sentence-number {
      display: grid;
      flex: 0 0 34px;
      width: 34px;
      height: 34px;
      place-items: center;
      border-radius: 8px;
      background: var(--text);
      color: var(--bg);
      font-size: 14px;
      font-weight: 850;
    }

    .writing-lab .chinese-line {
      margin: 0;
      color: var(--text);
      font-size: 18px;
      font-weight: 750;
      line-height: 1.55;
    }

    .writing-lab .sentence-copy {
      position: relative;
      min-width: 0;
      flex: 1;
    }

    .writing-lab .chunk-trigger {
      display: inline-block;
      appearance: none;
      border: 0;
      background: transparent;
      color: inherit;
      font: inherit;
      font-size: 17px;
      line-height: 1;
      margin-left: 4px;
      padding: 0;
      cursor: pointer;
      transition:
        transform 160ms ease,
        filter 160ms ease;
    }

    .writing-lab .chunk-trigger:hover,
    .writing-lab .chunk-trigger:focus-visible,
    .writing-lab .chunk-trigger[aria-expanded="true"] {
      filter: drop-shadow(0 0 6px color-mix(in srgb, var(--accent) 46%, transparent));
      outline: none;
      transform: translateY(-1px);
    }

    .writing-lab .chunk-trigger:focus-visible {
      border-radius: 4px;
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 16%, transparent);
    }

    .writing-lab .chunk-popover {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      z-index: 12;
      width: min(420px, calc(100vw - 56px));
      border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
      border-radius: 8px;
      background: var(--surface);
      padding: 12px;
      box-shadow: 0 18px 46px rgba(0, 0, 0, 0.14);
    }

    .writing-lab .chunk-popover[hidden] {
      display: none;
    }

    .writing-lab .chunk-popover::before {
      content: "";
      position: absolute;
      top: -6px;
      left: 18px;
      width: 10px;
      height: 10px;
      border-top: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
      border-left: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
      background: var(--surface);
      transform: rotate(45deg);
    }

    .writing-lab .chunk-popover-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .writing-lab .chunk-popover-head strong {
      color: var(--text);
      font-size: 14px;
      font-weight: 850;
    }

    .writing-lab .chunk-popover-head button {
      border: 1px solid var(--line);
      border-radius: 7px;
      background: var(--surface-soft);
      color: var(--muted);
      padding: 6px 9px;
      font: inherit;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
    }

    .writing-lab .chunk-popover-head button:hover,
    .writing-lab .chunk-popover-head button:focus-visible {
      border-color: var(--accent);
      color: var(--text);
    }

    .writing-lab .chunk-list {
      display: grid;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .writing-lab .chunk-list li {
      display: grid;
      gap: 4px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: color-mix(in srgb, var(--surface-soft) 62%, transparent);
      padding: 10px 12px;
    }

    .writing-lab .chunk-list span {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .writing-lab .chunk-list strong {
      color: var(--text);
      font-size: 15px;
      line-height: 1.45;
    }

    .writing-lab .chunk-empty {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .writing-lab .sentence-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      max-width: 360px;
    }

    .writing-lab .sentence-picker button {
      display: grid;
      position: relative;
      min-width: 38px;
      height: 38px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 8px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--surface-soft) 70%, transparent),
          var(--surface)
        );
      color: var(--text);
      font: inherit;
      font-size: 14px;
      font-weight: 850;
      cursor: pointer;
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        box-shadow 160ms ease,
        background 160ms ease,
        color 160ms ease;
    }

    .writing-lab .sentence-picker button:hover,
    .writing-lab .sentence-picker button:focus-visible {
      border-color: var(--accent);
      transform: translateY(-1px);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
    }

    .writing-lab .sentence-picker button.is-selected {
      border-color: var(--accent);
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--accent) 24%, var(--text)),
          var(--text)
        );
      color: var(--bg);
      box-shadow:
        0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent),
        0 10px 22px color-mix(in srgb, var(--text) 14%, transparent);
      transform: translateY(-1px);
    }

    .writing-lab .sentence-picker button.is-selected::after {
      content: "✓";
      position: absolute;
      top: -7px;
      right: -7px;
      display: grid;
      width: 18px;
      height: 18px;
      place-items: center;
      border: 2px solid var(--surface);
      border-radius: 999px;
      background: var(--accent);
      color: var(--bg);
      font-size: 11px;
      line-height: 1;
    }

    .writing-lab .sentence-picker button span {
      position: relative;
      z-index: 1;
    }

    .writing-lab .answer-box {
      border: 1px solid var(--line);
      border-radius: 10px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--surface-soft) 56%, transparent),
          var(--surface) 36%
        );
      padding: 12px;
      transition:
        border-color 160ms ease,
        box-shadow 160ms ease,
        background 160ms ease;
    }

    .writing-lab .answer-box:focus-within {
      border-color: var(--accent);
      background: var(--surface);
      box-shadow: 0 12px 30px color-mix(in srgb, var(--accent) 14%, transparent);
    }

    .writing-lab .answer-box-head,
    .writing-lab .answer-box-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 0 2px;
    }

    .writing-lab .answer-box-head {
      margin-bottom: 9px;
    }

    .writing-lab .answer-box-head span {
      color: var(--text);
      font-size: 14px;
      font-weight: 850;
    }

    .writing-lab .answer-box-head small,
    .writing-lab .answer-box-foot {
      color: var(--muted);
      font-size: 12px;
      font-weight: 650;
    }

    .writing-lab .answer-box-foot {
      justify-content: flex-end;
      margin-top: 8px;
      line-height: 1.45;
    }

    .writing-lab .answer-input {
      display: block;
      width: 100%;
      min-height: 118px;
      border: 1px solid transparent;
      border-radius: 8px;
      background: color-mix(in srgb, var(--surface) 92%, transparent);
      color: var(--text);
      padding: 15px 16px;
      font: inherit;
      line-height: 1.65;
      outline: none;
      resize: vertical;
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--line) 76%, transparent);
    }

    .writing-lab .answer-input::placeholder {
      color: color-mix(in srgb, var(--muted) 70%, transparent);
    }

    .writing-lab .answer-input:focus {
      border-color: transparent;
      box-shadow:
        inset 0 0 0 1px var(--accent),
        0 0 0 3px color-mix(in srgb, var(--accent) 14%, transparent);
    }

    .writing-lab .analysis-box {
      display: grid;
      gap: 14px;
      margin-top: 16px;
      border-top: 1px solid var(--line);
      padding-top: 16px;
    }

    .writing-lab .analysis-section {
      border-radius: 8px;
      background: var(--surface-soft);
      padding: 14px;
    }

    .writing-lab .compare-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .writing-lab .compare-item {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      padding: 12px;
    }

    .writing-lab .markdown-body {
      display: grid;
      gap: 10px;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.7;
    }

    .writing-lab .markdown-body h2,
    .writing-lab .markdown-body h3 {
      margin: 4px 0 8px;
      color: var(--text);
      font-size: 17px;
      line-height: 1.35;
    }

    .writing-lab .markdown-body p,
    .writing-lab .markdown-body ul,
    .writing-lab .markdown-body table {
      margin: 0 0 10px;
    }

    .writing-lab .markdown-body ul {
      padding-left: 20px;
    }

    .writing-lab .markdown-body li + li {
      margin-top: 8px;
    }

    .writing-lab .markdown-body table {
      display: block;
      width: 100%;
      overflow-x: auto;
      border-collapse: collapse;
    }

    .writing-lab .markdown-body th,
    .writing-lab .markdown-body td {
      border: 1px solid var(--line);
      padding: 10px 12px;
      text-align: left;
      vertical-align: top;
    }

    .writing-lab .markdown-body th {
      background: var(--surface);
      color: var(--text);
      font-weight: 800;
    }

    .writing-lab .markdown-body pre {
      overflow-x: auto;
      margin: 0;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #171717;
      padding: 14px 16px;
      color: #f6f1e8;
      white-space: pre-wrap;
    }

    .writing-lab .markdown-body code {
      font-family:
        "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
      font-size: 13px;
      line-height: 1.75;
    }

    .writing-lab .markdown-body :not(pre) > code {
      border-radius: 5px;
      background: var(--surface-soft);
      padding: 2px 5px;
      color: var(--text);
    }

    @media (max-width: 760px) {
      .writing-lab .compare-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    import MarkdownIt from "markdown-it";

    const markdown = new MarkdownIt({
      html: false,
      linkify: false,
      typographer: false
    });

    const lab = document.querySelector("[data-writing-lab]");
    const sourceText = lab?.querySelector("[data-source-text]");
    const sourceMeta = lab?.querySelector("[data-source-meta]");
    const splitButton = lab?.querySelector("[data-split-text]");
    const generateEssayButton = lab?.querySelector("[data-generate-essay]");
    const essayCategorySelect = lab?.querySelector("[data-essay-category]");
    const practicePanel = lab?.querySelector("[data-practice-panel]");
    const sentenceList = lab?.querySelector("[data-sentence-list]");
    const sentenceCount = lab?.querySelector("[data-sentence-count]");
    const checkBar = lab?.querySelector("[data-check-bar]");
    const checkBarToggle = lab?.querySelector("[data-check-bar-toggle]");
    const analysisTargets = lab?.querySelector("[data-analysis-targets]");
    const analyzeButton = lab?.querySelector("[data-analyze]");
    const exportPdfButton = lab?.querySelector("[data-export-pdf]");
    const exportDialog = lab?.querySelector("[data-export-dialog]");
    const exportDialogMessage = lab?.querySelector("[data-export-dialog-message]");
    const exportDialogClose = lab?.querySelector("[data-export-dialog-close]");
    const exportDocument = lab?.querySelector("[data-export-document]");

    let currentSentences = [];
    let selectedSentenceIndex = 0;
    let checkBarAnimationTimer;

    const setCheckBarCollapsed = (isCollapsed) => {
      if (!checkBar || !checkBarToggle) return;

      const isAlreadyCollapsed = checkBar.classList.contains("is-collapsed");
      if (isAlreadyCollapsed === isCollapsed) return;

      window.clearTimeout(checkBarAnimationTimer);
      checkBar.classList.remove("is-collapsing", "is-expanding");

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const finish = () => {
        checkBar.classList.toggle("is-collapsed", isCollapsed);
        checkBar.classList.remove("is-collapsing", "is-expanding");
        checkBarToggle.setAttribute("aria-expanded", String(!isCollapsed));
        checkBarToggle.textContent = isCollapsed ? "打开分析" : "隐藏检查栏";
      };

      if (prefersReducedMotion) {
        finish();
        return;
      }

      if (isCollapsed) {
        checkBar.classList.add("is-collapsing");
        checkBarToggle.setAttribute("aria-expanded", "false");
        checkBarAnimationTimer = window.setTimeout(finish, 180);
        return;
      }

      checkBar.classList.add("is-expanding");
      checkBar.classList.remove("is-collapsed");
      checkBarToggle.setAttribute("aria-expanded", "true");
      checkBarToggle.textContent = "隐藏检查栏";
      checkBarAnimationTimer = window.setTimeout(finish, 220);
    };

    const splitIntoSentences = (text) =>
      text
        .replace(/\s+/g, " ")
        .match(/[^.!?]+[.!?]+|[^.!?]+$/g)
        ?.map((sentence) => sentence.trim())
        .filter(Boolean) ?? [];

    const escapeHtml = (value) => {
      const div = document.createElement("div");
      div.textContent = value ?? "";
      return div.innerHTML;
    };

    const setError = (message) => {
      lab?.querySelector("[data-error]")?.remove();
      if (!message) return;

      const error = document.createElement("p");
      error.className = "error-message";
      error.dataset.error = "";
      error.textContent = message;
      sourceText?.insertAdjacentElement("afterend", error);
    };

    const hideExportDialog = () => {
      if (!exportDialog) return;
      exportDialog.hidden = true;
    };

    const showExportDialog = (message) => {
      if (!exportDialog || !exportDialogMessage) return;

      exportDialogMessage.textContent = message;
      exportDialog.hidden = false;
      exportDialogClose?.focus();
    };

    const buildExportDocument = (cards) => {
      if (!exportDocument || !sourceText) return;

      const sentenceSections = Array.from(cards)
        .map((card, index) => {
          const sentence = currentSentences[index] ?? {};
          const answer = card.querySelector("[data-user-answer]")?.value.trim() ?? "";
          const analysisBox = card.querySelector("[data-analysis-box]");

          return `
            <section class="export-sentence">
              <h2>句子 ${index + 1}</h2>
              <div>
                <span class="export-label">逐句中文</span>
                <p>${escapeHtml(sentence.chinese_text ?? "")}</p>
              </div>
              <div>
                <span class="export-label">用户输入的英文</span>
                <p class="export-user-answer">${escapeHtml(answer)}</p>
              </div>
              <div class="export-analysis">
                <span class="export-label">AI 分析</span>
                ${analysisBox?.innerHTML ?? ""}
              </div>
            </section>
          `;
        })
        .join("");

      exportDocument.innerHTML = `
        <h1>SRT Console 练习导出</h1>
        <section class="export-source">
          <span class="export-label">范文</span>
          <p>${escapeHtml(sourceText.value.trim())}</p>
        </section>
        ${sentenceSections}
      `;
    };

    const exportPracticeToPdf = (cards) => {
      if (!exportDocument) return;

      buildExportDocument(cards);
      document.body.classList.add("is-exporting-pdf");
      exportDocument.classList.add("is-exporting");
      exportDocument.setAttribute("aria-hidden", "false");

      const originalTitle = document.title;
      document.title = "SRT Console 练习导出";

      const cleanup = () => {
        document.body.classList.remove("is-exporting-pdf");
        exportDocument.classList.remove("is-exporting");
        exportDocument.setAttribute("aria-hidden", "true");
        document.title = originalTitle;
      };

      window.addEventListener("afterprint", cleanup, { once: true });
      window.print();
    };

    const postJson = async (url, body) => {
      const response = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      });

      const responseText = await response.text();
      let data = {};

      if (responseText) {
        try {
          data = JSON.parse(responseText);
        } catch {
          if (!response.ok) {
            throw new Error("请求失败，请稍后重试。");
          }

          throw new Error("AI 返回内容解析失败，请重新尝试。");
        }
      }

      if (!response.ok) {
        throw new Error(data.error ?? "请求失败，请稍后重试。");
      }

      return data;
    };

    const renderSentences = () => {
      if (!sentenceList || !practicePanel || !sentenceCount) return;

      sentenceList.innerHTML = currentSentences
        .map(
          (item, index) => `
            <article class="sentence-card" data-sentence-card data-index="${index}">
              <header>
                <span class="sentence-number">${index + 1}</span>
                <div class="sentence-copy">
                  <p class="chinese-line">
                    <span>${escapeHtml(item.chinese_text)}</span>
                    <button
                      class="chunk-trigger"
                      type="button"
                      data-chunk-trigger
                      aria-expanded="false"
                      aria-controls="chunk-panel-${index}"
                      title="查看 chunk 提示"
                    >
                      <span aria-hidden="true">💡</span>
                      <span class="sr-only">查看第 ${index + 1} 句的 chunk 提示</span>
                    </button>
                  </p>
                  <div
                    class="chunk-popover"
                    id="chunk-panel-${index}"
                    data-chunk-panel
                    hidden
                  >
                    <div class="chunk-popover-head">
                      <strong>Chunk 提示</strong>
                      <button type="button" data-chunk-close aria-label="关闭 chunk 提示">关闭</button>
                    </div>
                    ${
                      Array.isArray(item.chunks) && item.chunks.length
                        ? `<ul class="chunk-list">
                            ${item.chunks
                              .map(
                                (chunk) => `<li>
                                  <span>${escapeHtml(chunk.chinese ?? "")}</span>
                                  <strong>${escapeHtml(chunk.english ?? "")}</strong>
                                </li>`
                              )
                              .join("")}
                          </ul>`
                        : `<p class="chunk-empty">暂无可用 chunk。</p>`
                    }
                  </div>
                </div>
              </header>
              <div class="answer-box">
                <div class="answer-box-head">
                  <span>你的英文回译</span>
                  <small>Sentence ${index + 1}</small>
                </div>
                <textarea
                  class="answer-input"
                  data-user-answer
                  rows="4"
                  placeholder="Type your English translation here..."
                ></textarea>
                <div class="answer-box-foot">
                  <span>尽量保留原句逻辑，再尝试换成更自然的表达。</span>
                </div>
              </div>
              <div class="analysis-box" hidden data-analysis-box></div>
            </article>
          `
        )
        .join("");

      sentenceCount.textContent = `${currentSentences.length} 句`;
      renderAnalysisTargets();
      setCheckBarCollapsed(false);
      practicePanel.hidden = false;
    };

    const renderAnalysisTargets = () => {
      if (!analysisTargets) return;

      analysisTargets.innerHTML = currentSentences
        .map(
          (item, index) =>
            `<button
              class="${index === selectedSentenceIndex ? "is-selected" : ""}"
              type="button"
              data-analysis-target="${index}"
              aria-pressed="${index === selectedSentenceIndex ? "true" : "false"}"
              title="${escapeHtml(item.chinese_text)}"
            ><span>${index + 1}</span></button>`
        )
        .join("");
    };

    const selectSentence = (index, shouldScroll = true) => {
      if (!Number.isInteger(index) || !currentSentences[index]) return;

      selectedSentenceIndex = index;
      renderAnalysisTargets();

      if (!shouldScroll) return;

      lab
        ?.querySelector(`[data-sentence-card][data-index="${index}"]`)
        ?.scrollIntoView({ behavior: "smooth", block: "center" });
    };

    const renderList = (items, renderItem) =>
      Array.isArray(items) && items.length
        ? items.map(renderItem).join("")
        : "<li>暂无明显问题。</li>";

    const buildGrammarMarkdown = (analysis) => {
      if (analysis.grammar_markdown) return analysis.grammar_markdown;

      if (!Array.isArray(analysis.grammar_errors) || !analysis.grammar_errors.length) {
        return "## 语法分析\n\n暂无明显语法问题。";
      }

      return analysis.grammar_errors
        .map(
          (item, index) => `## 语法问题 ${index + 1}

- **错误片段**：${item.error}
- **原因**：${item.reason}

\`\`\`text
建议改法：${item.correction}
\`\`\`
`
        )
        .join("\n");
    };

    const buildIntroMarkdown = (item, answer) => `## 原题展示

| 类型 | 内容 |
| --- | --- |
| 原来的范文 | ${item.english_text} |
| 对应中文 | ${item.chinese_text} |
| 你的翻译 | ${answer || "未填写"} |
`;

    const buildLevelRewriteMarkdown = (analysis) => `## ${analysis.level_rewrite?.target_band ?? "6.5-7.0"} 改写

**${analysis.level_rewrite?.sentence ?? "暂无改写。"}**

${analysis.level_rewrite?.comment ?? "暂无说明。"}
`;

    const buildOverallMarkdown = (analysis) => `## 整体评价

${analysis.overall_comment ?? "暂无整体评价。"}
`;

    const buildExpressionMarkdown = (analysis) => {
      if (!Array.isArray(analysis.expression_comparison) || !analysis.expression_comparison.length) {
        return "## 表达对比\n\n暂无明显表达问题。";
      }

      return `## 表达对比

${analysis.expression_comparison
  .map(
    (item) => `- **用户表达**：${item.user_exp}
  - **更适合当前阶段**：${item.better_exp}
  - **参考原文**：${item.original_exp}
  - **语感差异**：${item.nuance_difference}`
  )
  .join("\n\n")}
`;
    };

    const buildStructureMarkdown = (analysis) => {
      const structure = analysis.logic_and_sentence_structure ?? {};

      return `## 逻辑与句子结构

- **你的结构**：${structure.user_structure ?? "暂无说明。"}
- **优化结构**：${structure.better_structure ?? "暂无说明。"}

${structure.analysis ?? "暂无结构分析。"}
`;
    };

    const buildChunksMarkdown = (analysis) => {
      if (!Array.isArray(analysis.chunks) || !analysis.chunks.length) {
        return "## Chunk 收集\n\n暂无特别需要积累的 chunk。";
      }

      return `## Chunk 收集

${analysis.chunks
  .map(
    (chunk) => `- **${chunk.english}**：${chunk.chinese}
  - 使用场景：${chunk.note}`
  )
  .join("\n\n")}
`;
    };

    const buildPatternsMarkdown = (analysis) => {
      if (!Array.isArray(analysis.sentence_patterns) || !analysis.sentence_patterns.length) {
        return "## 句型收集\n\n暂无特别需要积累的句型。";
      }

      return `## 句型收集

${analysis.sentence_patterns
  .map(
    (pattern) => `- **结构**：${pattern.structure}
  - **用法**：${pattern.usage}
  - **例句**：${pattern.example}`
  )
  .join("\n\n")}
`;
    };

    const buildRewritesMarkdown = (analysis) => `## 改写建议

- **基础改法**：${analysis.rewrites?.basic ?? "暂无基础改法。"}
- **地道改法**：${analysis.rewrites?.idiomatic ?? "暂无地道改法。"}
- **学术升级**：${analysis.rewrites?.advanced ?? "暂无学术升级。"}
`;

    const buildLearningFocusMarkdown = (analysis) => {
      if (!Array.isArray(analysis.learning_focus) || !analysis.learning_focus.length) {
        return "## 学习重点\n\n暂无学习重点。";
      }

      return `## 学习重点

${analysis.learning_focus.map((item) => `- ${item}`).join("\n")}
`;
    };

    const buildAnalysis = (item, answer, analysis, index) => `
      <div class="analysis-title">
        <span class="analysis-tag">AI 分析 ${index + 1}</span>
        <span class="analysis-tag">Score ${escapeHtml(analysis.score ?? "-")}</span>
      </div>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildIntroMarkdown(item, answer))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildLevelRewriteMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildOverallMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">
          ${markdown.render(buildGrammarMarkdown(analysis))}
        </div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildExpressionMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildStructureMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildChunksMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildPatternsMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildRewritesMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildLearningFocusMarkdown(analysis))}</div>
      </section>
    `;

    const getSelectedEssayCategoryLabel = () => {
      if (!essayCategorySelect) return "";
      const option = essayCategorySelect.selectedOptions?.[0];
      return option?.dataset.label ?? "";
    };

    const updateGenerateEssayButtonText = () => {
      if (!generateEssayButton) return;
      const categoryLabel = getSelectedEssayCategoryLabel();
      generateEssayButton.textContent = categoryLabel
        ? `AI生成随机${categoryLabel}类范文`
        : "AI生成随机分类范文";
    };

    sourceText?.addEventListener("input", () => {
      const count = splitIntoSentences(sourceText.value).length;
      if (sourceMeta) {
        sourceMeta.textContent = count ? `检测到约 ${count} 句` : "等待输入文章";
      }
    });

    essayCategorySelect?.addEventListener("change", updateGenerateEssayButtonText);
    updateGenerateEssayButtonText();

    generateEssayButton?.addEventListener("click", async () => {
      if (!sourceText) return;

      setError("");
      generateEssayButton.disabled = true;
      generateEssayButton.textContent = "AI生成中...";

      try {
        const data = await postJson("/api/ielts/generate-essay", {
          category: essayCategorySelect?.value ?? ""
        });
        const essay = data.essay ?? "";

        if (!essay) {
          throw new Error("AI 没有返回可用范文，请稍后重试。");
        }

        sourceText.value = essay;
        sourceText.dispatchEvent(new Event("input"));

        if (sourceMeta && data.category) {
          const count = splitIntoSentences(essay).length;
          const question = data.question ? `\n题目：\n${data.question}` : "";
          sourceMeta.textContent = `已生成 ${data.category} 分类范文${question}\n约 ${count} 句`;
        }
      } catch (error) {
        setError(error.message);
      } finally {
        generateEssayButton.disabled = false;
        updateGenerateEssayButtonText();
      }
    });

    splitButton?.addEventListener("click", async () => {
      if (!sourceText) return;
      const text = sourceText.value.trim();
      if (!text) {
        setError("请先粘贴一篇英文文章。");
        return;
      }

      setError("");
      splitButton.disabled = true;
      splitButton.textContent = "拆解中...";

      try {
        const data = await postJson("/api/ielts/split", { text });
        currentSentences = (data.sentences ?? []).map((item, index) => ({
          sequence: item.sequence ?? index + 1,
          english_text: item.english_text ?? item.en ?? "",
          chinese_text: item.chinese_text ?? item.zh ?? "",
          structure: item.structure ?? "",
          chunks: Array.isArray(item.chunks) ? item.chunks : []
        }));

        if (!currentSentences.length) {
          throw new Error("AI 没有返回可用句子，请重新尝试。");
        }

        selectedSentenceIndex = 0;
        renderSentences();
      } catch (error) {
        setError(error.message);
      } finally {
        splitButton.disabled = false;
        splitButton.textContent = "AI 拆解为中文";
      }
    });

    analysisTargets?.addEventListener("click", (event) => {
      const target = event.target;
      const button =
        target instanceof Element ? target.closest("[data-analysis-target]") : null;
      if (!button) return;

      selectSentence(Number(button.getAttribute("data-analysis-target")));
    });

    checkBarToggle?.addEventListener("click", () => {
      setCheckBarCollapsed(!checkBar?.classList.contains("is-collapsed"));
    });

    const setChunkPanelOpen = (card, isOpen) => {
      const trigger = card?.querySelector("[data-chunk-trigger]");
      const panel = card?.querySelector("[data-chunk-panel]");
      if (!trigger || !panel) return;

      panel.hidden = !isOpen;
      trigger.setAttribute("aria-expanded", String(isOpen));
    };

    sentenceList?.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const trigger = target.closest("[data-chunk-trigger]");
      if (trigger) {
        const card = trigger.closest("[data-sentence-card]");
        const isOpen = trigger.getAttribute("aria-expanded") === "true";
        if (!isOpen) {
          sentenceList
            ?.querySelectorAll("[data-sentence-card]")
            .forEach((item) => setChunkPanelOpen(item, false));
        }
        setChunkPanelOpen(card, !isOpen);
        return;
      }

      const closeButton = target.closest("[data-chunk-close]");
      if (closeButton) {
        const card = closeButton.closest("[data-sentence-card]");
        setChunkPanelOpen(card, false);
        const cardTrigger = card?.querySelector("[data-chunk-trigger]");
        if (cardTrigger instanceof HTMLElement) {
          cardTrigger.focus();
        }
      }
    });

    analyzeButton?.addEventListener("click", async () => {
      const selectedIndex = selectedSentenceIndex;

      if (!Number.isInteger(selectedIndex) || !currentSentences[selectedIndex]) {
        setError("请先选择要分析的句子序号。");
        return;
      }

      const cards = lab?.querySelectorAll("[data-sentence-card]") ?? [];
      const card = lab?.querySelector(`[data-sentence-card][data-index="${selectedIndex}"]`);
      const answer = card?.querySelector("[data-user-answer]")?.value.trim() ?? "";
      const sentence = {
        index: selectedIndex,
        english_text: currentSentences[selectedIndex]?.english_text ?? "",
        chinese_text: currentSentences[selectedIndex]?.chinese_text ?? "",
        structure: currentSentences[selectedIndex]?.structure ?? "",
        user_text: answer
      };

      if (!sentence.user_text) {
        setError("请先完成所选句子的英文回译，再进行 AI 分析。");
        return;
      }

      setError("");
      analyzeButton.disabled = true;
      analyzeButton.textContent = "分析所选句子中...";

      try {
        const data = await postJson("/api/ielts/analyze", {
          sentences: [
            {
              english_text: sentence.english_text,
              chinese_text: sentence.chinese_text,
              structure: sentence.structure,
              user_text: sentence.user_text
            }
          ]
        });
        const analysis = data.analyses?.[0];
        if (!analysis) return;

        const resultCard = Array.from(cards).find(
          (item) => Number(item.getAttribute("data-index")) === selectedIndex
        );
        const box = resultCard?.querySelector("[data-analysis-box]");
        if (!box || !currentSentences[selectedIndex]) return;
        box.innerHTML = buildAnalysis(
          currentSentences[selectedIndex],
          answer,
          analysis,
          selectedIndex
        );
        box.hidden = false;
      } catch (error) {
        setError(error.message);
      } finally {
        analyzeButton.disabled = false;
        analyzeButton.textContent = "AI 分析所选句子";
      }
    });

    exportPdfButton?.addEventListener("click", () => {
      const cards = lab?.querySelectorAll("[data-sentence-card]") ?? [];
      const incompleteIndexes = Array.from(cards)
        .filter((card) => {
          const answer = card.querySelector("[data-user-answer]")?.value.trim() ?? "";
          return !answer;
        })
        .map((card) => Number(card.getAttribute("data-index")) + 1)
        .filter(Number.isFinite);

      if (incompleteIndexes.length) {
        showExportDialog(`请先完成以下句子的英文回译：${incompleteIndexes.join("、")}`);
        return;
      }

      const missingAnalysisIndexes = Array.from(cards)
        .filter((card) => {
          const analysisBox = card.querySelector("[data-analysis-box]");
          return !analysisBox || analysisBox.hidden || !analysisBox.textContent?.trim();
        })
        .map((card) => Number(card.getAttribute("data-index")) + 1)
        .filter(Number.isFinite);

      if (missingAnalysisIndexes.length) {
        showExportDialog(`以下句子还没有完成 AI 分析：${missingAnalysisIndexes.join("、")}`);
        return;
      }

      exportPracticeToPdf(cards);
    });

    exportDialogClose?.addEventListener("click", hideExportDialog);

    exportDialog?.addEventListener("click", (event) => {
      if (event.target === exportDialog) {
        hideExportDialog();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && exportDialog && !exportDialog.hidden) {
        hideExportDialog();
      }

      if (event.key === "Escape") {
        lab
          ?.querySelectorAll("[data-sentence-card]")
          .forEach((card) => setChunkPanelOpen(card, false));
      }
    });
  </script>
</BaseLayout>
