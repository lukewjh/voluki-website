  <script>
    import MarkdownIt from "markdown-it";

    const markdown = new MarkdownIt({
      html: false,
      linkify: false,
      typographer: false
    });

    const lab = document.querySelector("[data-writing-lab]");
    const sourceText = lab?.querySelector("[data-source-text]");
    const sourceMeta = lab?.querySelector("[data-source-meta]");
    const splitButton = lab?.querySelector("[data-split-text]");
    const exampleButton = lab?.querySelector("[data-load-example]");
    const practicePanel = lab?.querySelector("[data-practice-panel]");
    const sentenceList = lab?.querySelector("[data-sentence-list]");
    const sentenceCount = lab?.querySelector("[data-sentence-count]");
    const analysisTargets = lab?.querySelector("[data-analysis-targets]");
    const analyzeButton = lab?.querySelector("[data-analyze]");

    const exampleText =
      "In many countries, young people are encouraged to take a gap year before starting university. This experience can help them develop independence and a clearer sense of purpose. However, without a concrete plan, a gap year may become an excuse to delay important decisions.";

    let currentSentences = [];
    let selectedSentenceIndex = 0;

    const splitIntoSentences = (text) =>
      text
        .replace(/\s+/g, " ")
        .match(/[^.!?]+[.!?]+|[^.!?]+$/g)
        ?.map((sentence) => sentence.trim())
        .filter(Boolean) ?? [];

    const escapeHtml = (value) => {
      const div = document.createElement("div");
      div.textContent = value ?? "";
      return div.innerHTML;
    };

    const setError = (message) => {
      lab?.querySelector("[data-error]")?.remove();
      if (!message) return;

      const error = document.createElement("p");
      error.className = "error-message";
      error.dataset.error = "";
      error.textContent = message;
      sourceText?.insertAdjacentElement("afterend", error);
    };

    const postJson = async (url, body) => {
      const response = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      });
      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error ?? "请求失败，请稍后重试。");
      }

      return data;
    };

    const renderSentences = () => {
      if (!sentenceList || !practicePanel || !sentenceCount) return;

      sentenceList.innerHTML = currentSentences
        .map(
          (item, index) => `
            <article class="sentence-card" data-sentence-card data-index="${index}">
              <header>
                <span class="sentence-number">${index + 1}</span>
                <div>
                  <p class="chinese-line">${escapeHtml(item.chinese_text)}</p>
                </div>
              </header>
              <div class="answer-box">
                <div class="answer-box-head">
                  <span>你的英文回译</span>
                  <small>Sentence ${index + 1}</small>
                </div>
                <textarea
                  class="answer-input"
                  data-user-answer
                  rows="4"
                  placeholder="Type your English translation here..."
                ></textarea>
                <div class="answer-box-foot">
                  <span>尽量保留原句逻辑，再尝试换成更自然的表达。</span>
                </div>
              </div>
              <div class="analysis-box" hidden data-analysis-box></div>
            </article>
          `
        )
        .join("");

      sentenceCount.textContent = `${currentSentences.length} 句`;
      renderAnalysisTargets();
      practicePanel.hidden = false;
    };

    const renderAnalysisTargets = () => {
      if (!analysisTargets) return;

      analysisTargets.innerHTML = currentSentences
        .map(
          (item, index) =>
            `<button
              class="${index === selectedSentenceIndex ? "is-selected" : ""}"
              type="button"
              data-analysis-target="${index}"
              aria-pressed="${index === selectedSentenceIndex ? "true" : "false"}"
              title="${escapeHtml(item.chinese_text)}"
            ><span>${index + 1}</span></button>`
        )
        .join("");
    };

    const selectSentence = (index, shouldScroll = true) => {
      if (!Number.isInteger(index) || !currentSentences[index]) return;

      selectedSentenceIndex = index;
      renderAnalysisTargets();

      if (!shouldScroll) return;

      lab
        ?.querySelector(`[data-sentence-card][data-index="${index}"]`)
        ?.scrollIntoView({ behavior: "smooth", block: "center" });
    };

    const renderList = (items, renderItem) =>
      Array.isArray(items) && items.length
        ? items.map(renderItem).join("")
        : "<li>暂无明显问题。</li>";

    const buildGrammarMarkdown = (analysis) => {
      if (analysis.grammar_markdown) return analysis.grammar_markdown;

      if (!Array.isArray(analysis.grammar_errors) || !analysis.grammar_errors.length) {
        return "## 语法分析\n\n暂无明显语法问题。";
      }

      return analysis.grammar_errors
        .map(
          (item, index) => `## 语法问题 ${index + 1}

- **错误片段**：${item.error}
- **原因**：${item.reason}

\`\`\`text
建议改法：${item.correction}
\`\`\`
`
        )
        .join("\n");
    };

    const buildIntroMarkdown = (item, answer) => `## 原题展示

| 类型 | 内容 |
| --- | --- |
| 原来的范文 | ${item.english_text} |
| 对应中文 | ${item.chinese_text} |
| 你的翻译 | ${answer || "未填写"} |
`;

    const buildLevelRewriteMarkdown = (analysis) => `## ${analysis.level_rewrite?.target_band ?? "6.5-7.0"} 改写

**${analysis.level_rewrite?.sentence ?? "暂无改写。"}**

${analysis.level_rewrite?.comment ?? "暂无说明。"}
`;

    const buildOverallMarkdown = (analysis) => `## 整体评价

${analysis.overall_comment ?? "暂无整体评价。"}
`;

    const buildExpressionMarkdown = (analysis) => {
      if (!Array.isArray(analysis.expression_comparison) || !analysis.expression_comparison.length) {
        return "## 表达对比\n\n暂无明显表达问题。";
      }

      return `## 表达对比

${analysis.expression_comparison
  .map(
    (item) => `- **用户表达**：${item.user_exp}
  - **更适合当前阶段**：${item.better_exp}
  - **参考原文**：${item.original_exp}
  - **语感差异**：${item.nuance_difference}`
  )
  .join("\n\n")}
`;
    };

    const buildStructureMarkdown = (analysis) => {
      const structure = analysis.logic_and_sentence_structure ?? {};

      return `## 逻辑与句子结构

- **你的结构**：${structure.user_structure ?? "暂无说明。"}
- **优化结构**：${structure.better_structure ?? "暂无说明。"}

${structure.analysis ?? "暂无结构分析。"}
`;
    };

    const buildChunksMarkdown = (analysis) => {
      if (!Array.isArray(analysis.chunks) || !analysis.chunks.length) {
        return "## Chunk 收集\n\n暂无特别需要积累的 chunk。";
      }

      return `## Chunk 收集

${analysis.chunks
  .map(
    (chunk) => `- **${chunk.english}**：${chunk.chinese}
  - 使用场景：${chunk.note}`
  )
  .join("\n\n")}
`;
    };

    const buildPatternsMarkdown = (analysis) => {
      if (!Array.isArray(analysis.sentence_patterns) || !analysis.sentence_patterns.length) {
        return "## 句型收集\n\n暂无特别需要积累的句型。";
      }

      return `## 句型收集

${analysis.sentence_patterns
  .map(
    (pattern) => `- **结构**：${pattern.structure}
  - **用法**：${pattern.usage}
  - **例句**：${pattern.example}`
  )
  .join("\n\n")}
`;
    };

    const buildRewritesMarkdown = (analysis) => `## 改写建议

- **基础改法**：${analysis.rewrites?.basic ?? "暂无基础改法。"}
- **地道改法**：${analysis.rewrites?.idiomatic ?? "暂无地道改法。"}
- **学术升级**：${analysis.rewrites?.advanced ?? "暂无学术升级。"}
`;

    const buildLearningFocusMarkdown = (analysis) => {
      if (!Array.isArray(analysis.learning_focus) || !analysis.learning_focus.length) {
        return "## 学习重点\n\n暂无学习重点。";
      }

      return `## 学习重点

${analysis.learning_focus.map((item) => `- ${item}`).join("\n")}
`;
    };

    const buildAnalysis = (item, answer, analysis, index) => `
      <div class="analysis-title">
        <span class="analysis-tag">AI 分析 ${index + 1}</span>
        <span class="analysis-tag">Score ${escapeHtml(analysis.score ?? "-")}</span>
      </div>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildIntroMarkdown(item, answer))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildLevelRewriteMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildOverallMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">
          ${markdown.render(buildGrammarMarkdown(analysis))}
        </div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildExpressionMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildStructureMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildChunksMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildPatternsMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildRewritesMarkdown(analysis))}</div>
      </section>
      <section class="analysis-section">
        <div class="markdown-body">${markdown.render(buildLearningFocusMarkdown(analysis))}</div>
      </section>
    `;

    sourceText?.addEventListener("input", () => {
      const count = splitIntoSentences(sourceText.value).length;
      if (sourceMeta) {
        sourceMeta.textContent = count ? `检测到约 ${count} 句` : "等待输入文章";
      }
    });

    exampleButton?.addEventListener("click", () => {
      if (!sourceText) return;
      sourceText.value = exampleText;
      sourceText.dispatchEvent(new Event("input"));
    });

    splitButton?.addEventListener("click", async () => {
      if (!sourceText) return;
      const text = sourceText.value.trim();
      if (!text) {
        setError("请先粘贴一篇英文文章。");
        return;
      }

      setError("");
      splitButton.disabled = true;
      splitButton.textContent = "拆解中...";

      try {
        const data = await postJson("/api/ielts/split", { text });
        currentSentences = (data.sentences ?? []).map((item, index) => ({
          sequence: item.sequence ?? index + 1,
          english_text: item.english_text ?? item.en ?? "",
          chinese_text: item.chinese_text ?? item.zh ?? "",
          structure: item.structure ?? ""
        }));
        selectedSentenceIndex = 0;
        renderSentences();
      } catch (error) {
        setError(error.message);
      } finally {
        splitButton.disabled = false;
        splitButton.textContent = "AI 拆解为中文";
      }
    });

    analysisTargets?.addEventListener("click", (event) => {
      const target = event.target;
      const button =
        target instanceof Element ? target.closest("[data-analysis-target]") : null;
      if (!button) return;

      selectSentence(Number(button.getAttribute("data-analysis-target")));
    });

    analyzeButton?.addEventListener("click", async () => {
      const selectedIndex = selectedSentenceIndex;

      if (!Number.isInteger(selectedIndex) || !currentSentences[selectedIndex]) {
        setError("请先选择要分析的句子序号。");
        return;
      }

      const cards = lab?.querySelectorAll("[data-sentence-card]") ?? [];
      const card = lab?.querySelector(`[data-sentence-card][data-index="${selectedIndex}"]`);
      const answer = card?.querySelector("[data-user-answer]")?.value.trim() ?? "";
      const sentence = {
        index: selectedIndex,
        english_text: currentSentences[selectedIndex]?.english_text ?? "",
        chinese_text: currentSentences[selectedIndex]?.chinese_text ?? "",
        structure: currentSentences[selectedIndex]?.structure ?? "",
        user_text: answer
      };

      if (!sentence.user_text) {
        setError("请先完成所选句子的英文回译，再进行 AI 分析。");
        return;
      }

      setError("");
      analyzeButton.disabled = true;
      analyzeButton.textContent = "分析所选句子中...";

      try {
        const data = await postJson("/api/ielts/analyze", {
          sentences: [
            {
              english_text: sentence.english_text,
              chinese_text: sentence.chinese_text,
              structure: sentence.structure,
              user_text: sentence.user_text
            }
          ]
        });
        const analysis = data.analyses?.[0];
        if (!analysis) return;

        const resultCard = Array.from(cards).find(
          (item) => Number(item.getAttribute("data-index")) === selectedIndex
        );
        const box = resultCard?.querySelector("[data-analysis-box]");
        if (!box || !currentSentences[selectedIndex]) return;
        box.innerHTML = buildAnalysis(
          currentSentences[selectedIndex],
          answer,
          analysis,
          selectedIndex
        );
        box.hidden = false;
      } catch (error) {
        setError(error.message);
      } finally {
        analyzeButton.disabled = false;
        analyzeButton.textContent = "AI 分析所选句子";
      }
    });
  </script>
</BaseLayout>
