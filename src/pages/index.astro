---
import BaseLayout from "../layouts/BaseLayout.astro";

const modules = [
  {
    title: "Blog",
    description: "阅读关于英语学习、技术、产品与日常思考的记录。",
    href: "/blog",
    label: "进入文章"
  },
  {
    title: "NewsRadar",
    description: "从关注的信息源中，快速查看值得留意的最新动态。",
    href: "/newsradar/",
    label: "打开 NewsRadar"
  },
  {
    title: "写作练习台",
    description: "通过句子逆向翻译练习，把输入、反馈与复盘放在同一个工作台。",
    href: "/ielts-writing/",
    label: "开始练习"
  },
  {
    title: "RIO",
    description: "随机 chunk 输入输出一体化，用来测试数据库读取与后续练习流程。",
    href: "/rio/",
    label: "打开 RIO"
  }
];
---

<BaseLayout title="Voluki" description="Voluki 的内容与工具入口。">
  <section class="home-directory" aria-label="内容与工具">
    <div class="module-grid">
      {modules.map((module) => (
        <a class="module-card" href={module.href}>
          <div>
            <h2>{module.title}</h2>
            <p>{module.description}</p>
          </div>
          <span class="module-link">
            {module.label}
            <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
